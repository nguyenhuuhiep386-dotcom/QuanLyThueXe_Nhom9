@model QuanLyThueXe.Models.Xe

@{
    ViewData["Title"] = "Thêm xe mới";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-plus"></i> Thêm Xe Mới</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="card shadow">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="TenXe" class="form-label"></label>
                        <input asp-for="TenXe" class="form-control" />
                        <span asp-validation-for="TenXe" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="BienSo" class="form-label"></label>
                        <input asp-for="BienSo" class="form-control" />
                        <span asp-validation-for="BienSo" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="MaHangXe" class="form-label">Hãng xe</label>
                        <select asp-for="MaHangXe" class="form-select" asp-items="ViewBag.MaHangXe">
                            <option value="">-- Chọn hãng xe --</option>
                        </select>
                        <span asp-validation-for="MaHangXe" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="MaPhongCach" class="form-label">Phong cách</label>
                        <select asp-for="MaPhongCach" class="form-select" asp-items="ViewBag.MaPhongCach">
                            <option value="">-- Chọn phong cách --</option>
                        </select>
                        <span asp-validation-for="MaPhongCach" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="GiaThueNgay" class="form-label"></label>
                        <input asp-for="GiaThueNgay" class="form-control" type="number" />
                        <span asp-validation-for="GiaThueNgay" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="NamSanXuat" class="form-label"></label>
                        <input asp-for="NamSanXuat" class="form-control" type="number" />
                        <span asp-validation-for="NamSanXuat" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="DungTich" class="form-label"></label>
                        <input asp-for="DungTich" class="form-control" type="number" />
                        <span asp-validation-for="DungTich" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="ConTrong">Còn trống</option>
                    <option value="DangThue">Đang thuê</option>
                    <option value="BaoDuong">Bảo dưỡng</option>
                </select>
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MoTa" class="form-label"></label>
                <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Hình ảnh</label>
                <input type="file" name="hinhAnhs" class="form-control" multiple accept="image/*" />
                <small class="text-muted">Có thể chọn nhiều hình ảnh</small>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save"></i> Lưu thông tin
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
