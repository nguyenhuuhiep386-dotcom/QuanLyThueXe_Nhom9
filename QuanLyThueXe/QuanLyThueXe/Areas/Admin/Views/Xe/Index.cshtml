@model IEnumerable<QuanLyThueXe.Models.Xe>

@{
    ViewData["Title"] = "Quản lý xe";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-motorcycle"></i> Quản Lý Xe</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Thêm xe mới
    </a>
</div>

<!-- Filter -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control" placeholder="Tìm kiếm..." value="@Context.Request.Query["search"]" />
                </div>
                <div class="col-md-3">
                    <select name="trangThai" class="form-select">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="ConTrong" selected="@(Context.Request.Query["trangThai"] == "ConTrong")">Còn trống</option>
                        <option value="DangThue" selected="@(Context.Request.Query["trangThai"] == "DangThue")">Đang thuê</option>
                        <option value="BaoDuong" selected="@(Context.Request.Query["trangThai"] == "BaoDuong")">Bảo dưỡng</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Tìm
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card shadow">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Hình ảnh</th>
                        <th>Tên xe</th>
                        <th>Biển số</th>
                        <th>Hãng</th>
                        <th>Giá thuê/ngày</th>
                        <th>Trạng thái</th>
                        <th>Đánh giá</th>
                        <th>Số lần thuê</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var xe in Model)
                    {
                        <tr>
                            <td>
                                @{
                                    var anhChinh = xe.HinhAnhs.FirstOrDefault(h => h.IsAnhChinh) ?? xe.HinhAnhs.FirstOrDefault();
                                    var imgSrc = anhChinh?.DuongDanAnh ?? "https://via.placeholder.com/100x60?text=No+Image";
                                }
                                <img src="@imgSrc" alt="@xe.TenXe" style="width: 100px; height: 60px; object-fit: cover;"
                                     onerror="this.src='https://via.placeholder.com/100x60?text=No+Image'" />
                            </td>
                            <td>@xe.TenXe</td>
                            <td><span class="badge bg-secondary">@xe.BienSo</span></td>
                            <td>@xe.HangXe.TenHang</td>
                            <td>@xe.GiaThueNgay.ToString("N0") VNĐ</td>
                            <td>
                                @if (xe.TrangThai == "ConTrong")
                                {
                                    <span class="badge bg-success">Còn trống</span>
                                }
                                else if (xe.TrangThai == "DangThue")
                                {
                                    <span class="badge bg-info">Đang thuê</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Bảo dưỡng</span>
                                }
                            </td>
                            <td>
                                @if (xe.DanhGiaTrungBinh > 0)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-star"></i> @xe.DanhGiaTrungBinh.ToString("0.0")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có</span>
                                }
                            </td>
                            <td>@xe.SoLanThue</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@xe.MaXe" class="btn btn-sm btn-info" title="Chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@xe.MaXe" class="btn btn-sm btn-warning" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@xe.MaXe" class="btn btn-sm btn-danger" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
