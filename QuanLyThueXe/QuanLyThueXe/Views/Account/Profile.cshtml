@model QuanLyThueXe.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<style>
    /* Design Tokens */
    :root {
        --profile-bg: #111111;
        --card-bg: #1C1C1E;
        --card-border: #2C2C2E;
        --accent: #E8731A;
        --text-main: #FFFFFF;
        --text-sub: #8E8E93;
        --success: #32D74B;
    }

    /* Common Components */
    .profile-title-area {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 32px;
    }
    .profile-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .profile-subtitle {
        color: var(--text-sub);
        font-size: 14px;
    }
    .tier-badge-top {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 8px 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 500;
    }

    .p-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
    }
    .p-card-header {
        font-size: 11px;
        color: var(--text-sub);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* User Info Card */
    .user-info-grid {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 24px;
    }
    .user-avatar-wrap {
        position: relative;
    }
    .user-avatar {
        width: 100px;
        height: 100px;
        border-radius: 12px;
        object-fit: cover;
    }
    .user-avatar-edit {
        position: absolute;
        bottom: -10px;
        right: -10px;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text-main);
        transition: 0.2s;
    }
    .user-avatar-edit:hover {
        color: var(--accent);
    }
    .user-name {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 4px;
    }
    .user-member-since {
        font-size: 11px;
        color: var(--text-sub);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 20px;
    }
    .user-details-row {
        display: flex;
        gap: 40px;
    }
    .user-detail-group h6 {
        font-size: 10px;
        color: var(--text-sub);
        text-transform: uppercase;
        margin-bottom: 8px;
    }
    .user-detail-group p {
        font-size: 13px;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .user-detail-group i {
        color: var(--text-sub);
        width: 14px;
    }

    /* Membership Card */
    .member-tier-title {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 20px;
    }
    .progress-bar-bg {
        height: 4px;
        background: #333;
        border-radius: 2px;
        margin-bottom: 8px;
        overflow: hidden;
    }
    .progress-bar-fill {
        height: 100%;
        background: var(--text-main);
        width: 60%;
        border-radius: 2px;
    }
    .points-info {
        font-size: 12px;
        color: var(--text-sub);
        margin-bottom: 24px;
    }
    .reward-box {
        background: rgba(232, 115, 26, 0.1);
        border: 1px solid rgba(232, 115, 26, 0.2);
        border-radius: 8px;
        padding: 16px;
    }
    .reward-title {
        font-size: 10px;
        color: var(--accent);
        text-transform: uppercase;
        margin-bottom: 8px;
    }
    .reward-desc {
        font-size: 14px;
        margin-bottom: 16px;
    }

    /* Current Trip Card */
    .trip-card-content {
        display: flex;
        gap: 24px;
        align-items: center;
    }
    .trip-image {
        width: 160px;
        height: 100px;
        border-radius: 8px;
        object-fit: cover;
    }
    .trip-name {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 16px;
    }
    .trip-dates {
        display: flex;
        gap: 24px;
        margin-bottom: 16px;
    }
    .trip-date-group h6 {
        font-size: 10px;
        color: var(--text-sub);
        text-transform: uppercase;
        margin-bottom: 4px;
    }
    .trip-date-group p {
        font-size: 14px;
        font-weight: 500;
        margin: 0;
    }
    .badge-renting {
        background: var(--success);
        color: #000;
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* Table */
    .p-table {
        width: 100%;
        border-collapse: collapse;
    }
    .p-table th {
        font-size: 10px;
        color: var(--text-sub);
        text-transform: uppercase;
        text-align: left;
        padding: 16px 0;
        border-bottom: 1px solid var(--card-border);
    }
    .p-table td {
        font-size: 14px;
        padding: 16px 0;
        border-bottom: 1px solid var(--card-border);
    }
    .p-table tr:last-child td {
        border-bottom: none;
    }

    /* Payment Cards */
    .payment-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .credit-card {
        background: linear-gradient(135deg, #2A2A2C, #1C1C1E);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        padding: 20px;
        position: relative;
    }
    .credit-card.default {
        border-color: rgba(255,255,255,0.2);
    }
    .card-type {
        font-size: 16px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 32px;
    }
    .card-number {
        font-size: 18px;
        letter-spacing: 2px;
        margin-bottom: 16px;
        font-family: monospace;
    }
    .card-footer {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        color: var(--text-sub);
    }
    .btn-add-card {
        background: transparent;
        border: 1px solid var(--card-border);
        color: var(--text-main);
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 10px;
        text-transform: uppercase;
        cursor: pointer;
    }
    
    /* Security Settings */
    .security-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px solid var(--card-border);
    }
    .security-item:last-child {
        border-bottom: none;
    }
    .security-item-info h5 {
        font-size: 14px;
        margin-bottom: 4px;
    }
    .security-item-info p {
        font-size: 11px;
        color: var(--text-sub);
        margin: 0;
    }
    .btn-edit-icon {
        color: var(--text-sub);
        background: transparent;
        border: none;
        cursor: pointer;
    }
    
    /* Login History */
    .device-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px solid var(--card-border);
    }
    .device-item:last-child {
        border-bottom: none;
    }
    .device-info {
        display: flex;
        gap: 16px;
        align-items: center;
    }
    .device-icon {
        font-size: 24px;
        color: var(--text-sub);
    }
    .device-details h5 {
        font-size: 14px;
        margin-bottom: 4px;
    }
    .device-details p {
        font-size: 11px;
        color: var(--text-sub);
        margin: 0;
    }

    /* UI Toggle Switch */
    .ui-switch {
        position: relative;
        display: inline-block;
        width: 36px;
        height: 20px;
    }
    .ui-switch input { opacity: 0; width: 0; height: 0; }
    .ui-slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #333;
        transition: .4s;
        border-radius: 20px;
    }
    .ui-slider:before {
        position: absolute;
        content: "";
        height: 16px;
        width: 16px;
        left: 2px;
        bottom: 2px;
        background-color: white;
        transition: .4s;
        border-radius: 50%;
    }
    input:checked + .ui-slider { background-color: var(--text-main); }
    input:checked + .ui-slider:before { transform: translateX(16px); background-color: #000; }
</style>

<!-- Tab Content -->
<div class="tab-content" id="v-pills-tabContent">
    
    <!-- ==================== PROFILE TAB ==================== -->
    <div class="tab-pane fade show active" id="v-pills-profile" role="tabpanel">
        
        <!-- Header -->
        <div class="profile-title-area">
            <div>
                <h1 class="profile-title">Hồ sơ Cá nhân</h1>
                <p class="profile-subtitle">Quản lý thông tin và hành trình của bạn.</p>
            </div>
            <div class="tier-badge-top" style="border-color:@ViewBag.TierColor;">
                <i class="fas fa-star" style="color:@ViewBag.TierColor;"></i>
                <span>THÀNH VIÊN @ViewBag.Tier.ToUpper()</span>
                <span style="color:var(--text-sub);">|</span>
                <span style="color:var(--text-sub);">@ViewBag.Points.ToString("N0") điểm thưởng</span>
            </div>
        </div>

        <div class="row g-4">
            <!-- Left Column: User Info & Trip -->
            <div class="col-lg-8">
                
                <!-- User Info Card -->
                <div class="p-card">
                    <div class="user-info-grid">
                        <div class="user-avatar-wrap">
                            <img src="https://ui-avatars.com/api/?name=@(Model.HoTen ?? "User")&background=e8731a&color=fff&size=100" class="user-avatar" id="profileAvatar" />
                            <label for="avatarUpload" class="user-avatar-edit">
                                <i class="fas fa-pencil-alt" style="font-size: 12px;"></i>
                            </label>
                            <input type="file" id="avatarUpload" accept="image/*" style="display: none;" onchange="previewAvatar(this)" />
                        </div>
                        <div>
                            <h2 class="user-name">@(string.IsNullOrEmpty(Model.HoTen) ? "Chưa cập nhật" : Model.HoTen)</h2>
                            <p class="user-member-since">KHÁCH HÀNG TỪ 2022</p>
                            
                            <div class="user-details-row">
                                <div class="user-detail-group">
                                    <h6>THÔNG TIN LIÊN HỆ</h6>
                                    <p><i class="far fa-envelope"></i> @(string.IsNullOrEmpty(Model.Email) ? "Chưa có email" : Model.Email)</p>
                                    <p><i class="fas fa-phone-alt"></i> @(string.IsNullOrEmpty(Model.SoDienThoai) ? "Chưa có SĐT" : Model.SoDienThoai)</p>
                                </div>
                                <div class="user-detail-group">
                                    <h6>GIẤY PHÉP LÁI XE</h6>
                                    <p style="color:var(--success);"><i class="far fa-check-circle" style="color:var(--success);"></i> Hạng A2 - @(string.IsNullOrEmpty(Model.SoGPLX) ? "Chưa cập nhật" : Model.SoGPLX)</p>
                                    <a href="#" data-bs-toggle="modal" data-bs-target="#editProfileModal" style="color:var(--text-sub); text-decoration:none; font-size:11px; margin-left:22px; font-weight:600;"><i class="fas fa-pen" style="font-size:10px; margin-right:4px;"></i> CHỈNH SỬA HỒ SƠ</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Current Trip Card -->
                <div class="p-card" style="position:relative;">
                    <div style="position:absolute; top:24px; right:24px;">
                        <span class="badge-renting">ĐANG THUÊ</span>
                    </div>
                    <div class="p-card-header">CHUYẾN ĐI HIỆN TẠI</div>
                    <div class="trip-card-content">
                        <img src="https://images.unsplash.com/photo-1558981285-6f0c94958bb6?w=400&q=80" class="trip-image" />
                        <div>
                            <h3 class="trip-name">Fat Boy 114</h3>
                            <div class="trip-dates">
                                <div class="trip-date-group">
                                    <h6>NGÀY NHẬN</h6>
                                    <p>15/10/2023</p>
                                </div>
                                <div class="trip-date-group">
                                    <h6>NGÀY TRẢ</h6>
                                    <p>20/10/2023</p>
                                </div>
                            </div>
                            <button class="btn-hd-outline" data-bs-toggle="modal" data-bs-target="#tripDetailsModal" style="padding: 8px 16px; font-size:11px;">QUẢN LÝ CHUYẾN ĐI</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Membership -->
            <div class="col-lg-4">
                <div class="p-card" style="height: 100%; border-top: 4px solid @ViewBag.TierColor;">
                    <div class="p-card-header">
                        HẠNG THÀNH VIÊN
                        <i class="fas fa-medal" style="font-size:16px; color:@ViewBag.TierColor;"></i>
                    </div>
                    <h3 class="member-tier-title">Thành viên @ViewBag.Tier</h3>
                    
                    @{
                        int pts = ViewBag.Points ?? 0;
                        int next = ViewBag.NextTierPoints ?? 500;
                        int percent = next == 0 ? 100 : (pts * 100 / (pts + next));
                    }
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width:@percent%; background:@ViewBag.TierColor;"></div>
                    </div>
                    @if (next > 0) {
                        <p class="points-info">Còn @next.ToString("N0") điểm để lên hạng tiếp theo</p>
                    } else {
                        <p class="points-info">Bạn đã đạt hạng cao nhất!</p>
                    }
                    
                    <div class="reward-box" style="background:rgba(255,255,255,0.05); border-color:var(--card-border);">
                        <div class="reward-title">ƯU ĐÃI HIỆN CÓ</div>
                        <p class="reward-desc">@if(pts>2000){<text>Giảm 20% cho lần thuê tiếp theo</text>}else if(pts>500){<text>Giảm 10% cho lần thuê tiếp theo</text>}else{<text>Tích luỹ thêm để nhận ưu đãi</text>}</p>
                    </div>
                </div>
            </div>
            
            <!-- Bottom Row: History -->
            <div class="col-lg-12">
                <div class="p-card">
                    <h3 style="font-size:18px; font-weight:600; margin-bottom:24px;">Lịch sử đánh giá</h3>
                    @if (ViewBag.DanhGias != null && ((IEnumerable<QuanLyThueXe.Models.DanhGia>)ViewBag.DanhGias).Any())
                    {
                        <table class="p-table">
                            <thead>
                                <tr>
                                    <th>NGÀY ĐÁNH GIÁ</th>
                                    <th>MẪU XE</th>
                                    <th>ĐÁNH GIÁ</th>
                                    <th>SỐ SAO</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dg in (IEnumerable<QuanLyThueXe.Models.DanhGia>)ViewBag.DanhGias)
                                {
                                    <tr>
                                        <td style="color:var(--text-sub);">@dg.NgayDanhGia.ToString("dd/MM/yyyy")</td>
                                        <td><a href="@Url.Action("ChiTiet", "Xe", new { id = dg.MaXe })" style="color:var(--text-main); text-decoration:none;">@dg.Xe.TenXe</a></td>
                                        <td style="color:var(--text-sub); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@dg.NhanXet">
                                            @(string.IsNullOrEmpty(dg.NhanXet) ? "(Không có nhận xét)" : dg.NhanXet.Replace("\n", " "))
                                        </td>
                                        <td style="color:#fbbf24; font-size:12px;">
                                            @for (int i = 0; i < dg.SoSao; i++) { <i class="fas fa-star"></i> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p style="color:var(--text-sub); font-style:italic;">Bạn chưa có đánh giá nào.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== SETTINGS TAB ==================== -->
    <div class="tab-pane fade" id="v-pills-settings" role="tabpanel">
        
        <!-- Header -->
        <div class="profile-title-area">
            <div>
                <h1 class="profile-title">Cài đặt tài khoản</h1>
                <p class="profile-subtitle">Quản lý phương thức thanh toán, quyền bảo mật và riêng tư, và phiên đăng nhập của bạn</p>
            </div>
        </div>

        <div class="row g-4">
            <!-- Left Column: Payment & Login History -->
            <div class="col-lg-8">
                <div class="p-card">
                    <div class="p-card-header" style="font-size:14px; font-weight:600; text-transform:none; color:var(--text-main);">
                        <span><i class="far fa-credit-card" style="margin-right:8px; color:var(--accent);"></i> Phương thức thanh toán</span>
                        <button class="btn-add-card" data-bs-toggle="modal" data-bs-target="#addCardModal">+ THÊM CARD</button>
                    </div>
                    
                    <div class="payment-grid">
                        <div class="credit-card default">
                            <span style="position:absolute; top:20px; right:20px; font-size:10px; background:rgba(255,255,255,0.1); padding:2px 8px; border-radius:4px;">Mặc định</span>
                            <div class="card-type">VISA</div>
                            <div class="card-number">**** **** **** 4242</div>
                            <div class="card-footer">
                                <span>Expires 12/25</span>
                                <i class="far fa-trash-alt" style="cursor:pointer;" onclick="showToast('Tính năng xoá thẻ đang phát triển', 'error')"></i>
                            </div>
                        </div>
                        <div class="credit-card">
                            <div class="card-type">MASTERCARD</div>
                            <div class="card-number">**** **** **** 8899</div>
                            <div class="card-footer">
                                <span>Expires 08/26</span>
                                <i class="far fa-trash-alt" style="cursor:pointer;" onclick="showToast('Tính năng xoá thẻ đang phát triển', 'error')"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-card">
                    <div class="p-card-header" style="font-size:14px; font-weight:600; text-transform:none; color:var(--text-main);">
                        <span><i class="fas fa-history" style="margin-right:8px; color:var(--accent);"></i> Lịch sử đăng nhập</span>
                    </div>
                    
                    <div>
                        <div class="device-item">
                            <div class="device-info">
                                <i class="fas fa-laptop device-icon"></i>
                                <div class="device-details">
                                    <h5>MacBook Pro - Chrome</h5>
                                    <p>Đà Nẵng, Việt Nam • IP: 192.168.1.1</p>
                                </div>
                            </div>
                            <div style="font-size:10px; color:var(--accent); text-transform:uppercase; font-weight:600;">ĐANG HOẠT ĐỘNG</div>
                        </div>
                        <div class="device-item">
                            <div class="device-info">
                                <i class="fas fa-mobile-alt device-icon" style="padding:0 4px;"></i>
                                <div class="device-details">
                                    <h5>iPhone 14 Pro Max - Safari</h5>
                                    <p>Huế, Thành Phố Huế • IP: 10.0.0.45</p>
                                </div>
                            </div>
                            <div style="text-align:right;">
                                <div style="font-size:11px; color:var(--text-sub); margin-bottom:4px;">15/05/2026, 14:30</div>
                                <div style="font-size:11px; color:var(--text-main); cursor:pointer;" onclick="showToast('Đã xóa thiết bị đăng nhập', 'success')">Xóa thiết bị</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Security -->
            <div class="col-lg-4">
                <div class="p-card">
                    <div class="p-card-header" style="font-size:14px; font-weight:600; text-transform:none; color:var(--text-main);">
                        <span><i class="fas fa-shield-alt" style="margin-right:8px; color:var(--accent);"></i> Bảo mật</span>
                    </div>
                    
                    <div class="security-item">
                        <div class="security-item-info">
                            <h5>Mật khẩu</h5>
                            <p>Thay đổi lần cuối vào lúc 3 tháng trước</p>
                        </div>
                        <button class="btn-edit-icon" data-bs-toggle="modal" data-bs-target="#changePasswordModal"><i class="fas fa-pencil-alt"></i></button>
                    </div>
                    
                    <div class="security-item">
                        <div class="security-item-info">
                            <h5>2 Bước xác thực</h5>
                            <p>Hiện tại đang tắt</p>
                        </div>
                        <label class="ui-switch">
                            <input type="checkbox" onchange="showToast(this.checked ? 'Đã bật xác thực 2 lớp' : 'Đã tắt xác thực 2 lớp', 'success')">
                            <span class="ui-slider"></span>
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ==================== MODALS ==================== -->
<style>
    .hd-modal .modal-content {
        background-color: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 16px;
    }
    .hd-modal .modal-header {
        border-bottom: 1px solid var(--card-border);
        padding: 20px 24px;
    }
    .hd-modal .modal-title {
        font-size: 18px;
        font-weight: 600;
        color: var(--text-main);
    }
    .hd-modal .btn-close {
        filter: invert(1) grayscale(100%) brightness(200%);
    }
    .hd-modal .modal-body {
        padding: 24px;
    }
    .hd-modal .modal-footer {
        border-top: 1px solid var(--card-border);
        padding: 16px 24px;
    }
    .hd-form-control {
        background-color: var(--profile-bg);
        border: 1px solid var(--card-border);
        color: var(--text-main);
        border-radius: 8px;
        padding: 12px 16px;
    }
    .hd-form-control:focus {
        background-color: var(--profile-bg);
        border-color: var(--accent);
        color: var(--text-main);
        box-shadow: none;
    }
