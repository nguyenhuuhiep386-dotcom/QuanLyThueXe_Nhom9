<!-- CSRF Token for Avatar Upload -->
@Html.AntiForgeryToken()

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Tự động xử lý sự kiện chuyển tab (khắc phục lỗi Bootstrap 5 không nhận diện thẻ <a> nằm ngoài thẻ .nav)
            const triggerTabList = document.querySelectorAll('.hd-sidebar-nav a[data-bs-toggle="pill"]');
            triggerTabList.forEach(triggerEl => {
                triggerEl.addEventListener('click', event => {
                    event.preventDefault();
                    
                    const targetId = triggerEl.getAttribute('data-bs-target');
                    if (targetId) {
                        // Xóa active khỏi tất cả các tab
                        document.querySelectorAll('.tab-pane').forEach(pane => {
                            pane.classList.remove('show', 'active');
                        });
                        
                        // Xóa active khỏi các nút bấm
                        triggerTabList.forEach(btn => btn.classList.remove('active'));
                        
                        // Thêm active vào tab mục tiêu
                        document.querySelector(targetId).classList.add('show', 'active');
                        triggerEl.classList.add('active');
                    }
                });
            });

            // Restore avatar from localStorage
            let savedAvatar = localStorage.getItem('userAvatar_@User.Identity?.Name');
            if (savedAvatar) {
                document.getElementById('profileAvatar').src = savedAvatar;
            }

            // Format card expiry MM/YY
            document.getElementById('newCardExp')?.addEventListener('input', function(e) {
                let val = this.value.replace(/\D/g, '');
                if (val.length >= 2) {
                    let month = parseInt(val.substring(0, 2));
                    if (month > 12) month = 12;
                    if (month < 1 && val.length === 2) month = 1;
                    val = (month < 10 ? '0' : '') + month + val.substring(2);
                }
                if (val.length >= 3) {
                    this.value = val.substring(0, 2) + '/' + val.substring(2, 4);
                } else {
                    this.value = val;
                }
            });
        });

        // Avatar preview and upload
        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const reader = new FileReader();
                
                // Preview tức thì
                reader.onload = function(e) {
                    document.getElementById('profileAvatar').src = e.target.result;
                };
                reader.readAsDataURL(file);
                
                // Upload to server
                const formData = new FormData();
                formData.append('avatar', file);
                
                // Lấy AntiForgery token từ form
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                const headers = {};
                if (tokenInput) {
                    headers['RequestVerificationToken'] = tokenInput.value;
                }
                
                fetch('/Account/UploadAvatar', {
                    method: 'POST',
                    body: formData,
                    headers: headers
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Cập nhật src bằng URL server
                        document.getElementById('profileAvatar').src = data.avatarUrl + '?t=' + Date.now();
                        localStorage.setItem('userAvatar_@User.Identity?.Name', data.avatarUrl);
                        showToast('Đã cập nhật ảnh đại diện', 'success');
                    } else {
                        showToast(data.message || 'Không thể tải ảnh lên', 'error');
                    }
                })
                .catch(error => {
                    console.error('Upload error:', error);
                    showToast('Đã xảy ra lỗi khi tải ảnh lên', 'error');
                });
            }
        }

        function addNewCard() {
            let num = document.getElementById('newCardNum').value.trim();
            let exp = document.getElementById('newCardExp').value.trim();
            if(!num || !exp) { showToast('Vui lòng nhập đủ thông tin thẻ (Số thẻ, Ngày hết hạn)', 'error'); return; }
            
            // Validate expiry
            let expParts = exp.split('/');
            if (expParts.length === 2) {
                let m = parseInt(expParts[0]);
                let y = parseInt('20' + expParts[1]);
                let now = new Date();
                if (y < now.getFullYear() || (y === now.getFullYear() && m < (now.getMonth() + 1))) {
                    showToast('Thẻ đã hết hạn!', 'error');
                    return;
                }
            } else {
                showToast('Định dạng ngày hết hạn không hợp lệ (MM/YY)', 'error');
                return;
            }
            
            let last4 = num.replace(/\s/g, '').slice(-4);
            if(last4.length < 4) last4 = "****";
            
            let html = `
            <div class="credit-card" style="animation: fadeIn 0.3s ease-out;">
                <div class="card-type">NEW CARD</div>
                <div class="card-number">**** **** **** ${last4}</div>
                <div class="card-footer">
                    <span>Expires ${exp}</span>
                    <i class="far fa-trash-alt" style="cursor:pointer;" onclick="this.closest('.credit-card').remove(); showToast('Đã xóa thẻ', 'success')"></i>
                </div>
            </div>`;
            
            document.querySelector('.payment-grid').insertAdjacentHTML('beforeend', html);
            showToast('Thêm thẻ thành công!', 'success');
            var modal = bootstrap.Modal.getInstance(document.getElementById('addCardModal'));
            modal.hide();
            
            document.getElementById('newCardNum').value = '';
            document.getElementById('newCardName').value = '';
            document.getElementById('newCardExp').value = '';
            document.getElementById('newCardCvv').value = '';
        }

        function changePassword() {
            const cur = document.getElementById('cpCurrent').value;
            const n = document.getElementById('cpNew').value;
            const conf = document.getElementById('cpConfirm').value;
            if(!cur || !n || !conf) { showToast('Vui lòng nhập đủ thông tin', 'error'); return; }
            
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const headers = { 'Content-Type': 'application/json' };
            if (tokenInput) headers['RequestVerificationToken'] = tokenInput.value;
            
            fetch('/Account/ChangePassword', {
                method: 'POST',
                headers: headers,
                body: JSON.stringify({ CurrentPassword: cur, NewPassword: n, ConfirmPassword: conf })
            })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    showToast(data.message, 'success');
                    var modal = bootstrap.Modal.getInstance(document.getElementById('changePasswordModal'));
                    modal.hide();
                    document.getElementById('cpCurrent').value = '';
                    document.getElementById('cpNew').value = '';
                    document.getElementById('cpConfirm').value = '';
                } else {
                    showToast(data.message, 'error');
                }
            })
            .catch(e => showToast('Đã xảy ra lỗi kết nối', 'error'));
        }

        function showToast(message, type = 'error') {
            const Toast = Swal.mixin({
                toast: true,
                position: 'bottom-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: 'var(--bg-card)',
                color: 'var(--text-primary)',
                iconColor: type === 'error' ? '#ef4444' : '#22c55e'
            });

            Toast.fire({
                icon: type,
                title: message
            });
        }
    </script>
}
