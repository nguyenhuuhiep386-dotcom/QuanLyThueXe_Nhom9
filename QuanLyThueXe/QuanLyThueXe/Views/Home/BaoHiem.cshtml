@{
    ViewData["Title"] = "Bảo hiểm";
}

<h1 style="font-size:28px; font-weight:700; font-style:italic; margin-bottom:8px;">Bảo hiểm cá nhân</h1>
<p style="font-size:14px; color:var(--text-secondary); margin-bottom:32px;">Xem chi tiết các gói bảo hiểm hiện tại của bạn và gửi yêu cầu bồi thường nhanh chóng khi có sự cố trên đường.</p>

<!-- Insurance Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div style="border-radius:var(--border-radius); overflow:hidden; border:1px solid var(--border-color);">
            <div style="height:160px; background:linear-gradient(135deg, #1a1a2e, #2a2a3e); display:flex; align-items:center; justify-content:center;">
                <img src="https://images.unsplash.com/photo-1558981285-6f0c94958bb6?w=500&q=80" 
                     style="width:100%; height:100%; object-fit:cover; opacity:0.5;" alt="Insurance"
                     onerror="this.style.display='none'" />
            </div>
            <div style="padding:20px; background:var(--bg-card);">
                <span style="background:#065f46; color:#34d399; padding:4px 10px; border-radius:4px; font-size:10px; font-weight:600;">ĐANG HOẠT ĐỘNG</span>
                <h4 style="font-size:18px; font-weight:700; margin:12px 0 4px;">H-D Premium Protection</h4>
                <div style="font-size:13px; color:var(--text-muted); margin-bottom:12px;">
                    <i class="fas fa-calendar"></i> Ngày hết hạn: <strong>15/11/2024</strong>
                </div>
                <div style="font-size:13px; color:var(--text-secondary); margin-bottom:4px;"><i class="fas fa-shield-alt" style="color:var(--accent);"></i> Phạm vi bảo hiểm:</div>
                <ul style="font-size:13px; color:var(--text-secondary); padding-left:20px; margin-bottom:16px;">
                    <li>Tai nạn toàn diện</li>
                    <li>Bị đánh cắp & Cháy nổ</li>
                    <li>Trách nhiệm dân sự (Mức cao)</li>
                </ul>
                <button class="btn-hd-outline w-100" style="text-align:center;" data-bs-toggle="modal" data-bs-target="#contractModal">Xem hợp đồng</button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div style="border-radius:var(--border-radius); overflow:hidden; border:1px solid var(--border-color);">
            <div style="height:160px; background:linear-gradient(135deg, #2a1a0a, #3a2a1a); display:flex; align-items:center; justify-content:center;">
                <img src="https://images.unsplash.com/photo-1609630875171-b1321377ee65?w=500&q=80"
                     style="width:100%; height:100%; object-fit:cover; opacity:0.5;" alt="Roadside"
                     onerror="this.style.display='none'" />
            </div>
            <div style="padding:20px; background:var(--bg-card);">
                <span style="background:#065f46; color:#34d399; padding:4px 10px; border-radius:4px; font-size:10px; font-weight:600;">ĐANG HOẠT ĐỘNG</span>
                <h4 style="font-size:18px; font-weight:700; margin:12px 0 4px;">Roadside Assistance</h4>
                <div style="font-size:13px; color:var(--text-muted); margin-bottom:12px;">
                    <i class="fas fa-calendar"></i> Ngày hết hạn: <strong>15/11/2024</strong>
                </div>
                <div style="font-size:13px; color:var(--text-secondary); margin-bottom:4px;"><i class="fas fa-wrench" style="color:var(--accent);"></i> Dịch vụ bao gồm:</div>
                <ul style="font-size:13px; color:var(--text-secondary); padding-left:20px; margin-bottom:16px;">
                    <li>Cứu hộ 24/7 toàn quốc</li>
                    <li>Sửa chữa lốp xe lưu động</li>
                    <li>Cấp nhiên liệu khẩn cấp</li>
                </ul>
                <button class="btn-hd w-100" style="text-align:center; justify-content:center;" data-bs-toggle="modal" data-bs-target="#callModal" onclick="startCallAnimation()">Gọi cứu hộ ngay</button>
            </div>
        </div>
    </div>
</div>

<!-- Claims Section -->
<div class="row g-4">
    <div class="col-md-5">
        <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:24px;">
            <h4 style="font-size:18px; font-weight:600; margin-bottom:20px;">
                <i class="fas fa-file-alt" style="color:var(--accent);"></i> Gửi yêu cầu bồi thường
            </h4>
            <div class="mb-3">
                <label class="form-label">LOẠI SỰ CỐ</label>
                <select class="form-select" style="font-size:13px;">
                    <option>Tai nạn va chạm</option>
                    <option>Hỏng xe giữa đường</option>
                    <option>Mất cắp</option>
                    <option>Khác</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">MÔ TẢ NGẮN GỌN</label>
                <textarea class="form-control" rows="3" placeholder="Mô tả chi tiết tình huống..." style="font-size:13px;"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">HÌNH ẢNH HIỆN TRƯỜNG</label>
                <input type="file" 
                       class="form-control" 
                       id="claimImages" 
                       accept="image/*" 
                       multiple />
                <small class="text-muted">Có thể chọn nhiều ảnh (Max 5MB mỗi ảnh)</small>
            </div>
            <div class="form-check mb-4 mt-3">
                <input class="form-check-input" type="checkbox" id="agreeCheckbox" onchange="document.getElementById('btnSubmitClaim').disabled = !this.checked; document.getElementById('btnSubmitClaim').style.opacity = this.checked ? '1' : '0.5'; document.getElementById('btnSubmitClaim').style.cursor = this.checked ? 'pointer' : 'not-allowed';">
                <label class="form-check-label" style="font-size:13px; color:var(--text-secondary);" for="agreeCheckbox">
                    Tôi cam kết các thông tin và hình ảnh cung cấp là hoàn toàn chính xác và chịu trách nhiệm trước pháp luật.
                </label>
            </div>
            <button type="button" id="btnSubmitClaim" class="btn-hd w-100" style="justify-content:center; opacity:0.5; cursor:not-allowed;" onclick="submitClaim()" disabled>
                <i class="fas fa-paper-plane"></i> Gửi yêu cầu (Claim)
            </button>
        </div>
    </div>
    <div class="col-md-7">
        <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:24px;">
            <h4 style="font-size:18px; font-weight:600; margin-bottom:20px;">Lịch sử Yêu cầu bồi thường</h4>
            <div id="claimHistoryContainer">
                <div class="hd-empty-state" style="padding:40px;">
                    <div style="font-size:48px; color:var(--text-muted); margin-bottom:16px;"><i class="fas fa-clipboard-check"></i></div>
                    <h5 style="font-size:16px; font-weight:600;">Chưa có yêu cầu nào</h5>
                    <p style="font-size:13px; color:var(--text-secondary);">Bạn chưa ghi nhận bất kỳ sự cố hay yêu cầu bồi thường nào. Lịch sử các hồ sơ claim sẽ hiển thị tại đây.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Contract Modal -->
<div class="modal fade hd-modal" id="contractModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:12px;">
            <div class="modal-header" style="border-bottom:1px solid var(--border-color);">
                <h5 class="modal-title" style="font-weight:700; font-size:18px;"><i class="fas fa-file-contract" style="color:var(--accent);"></i> Hợp Đồng Bảo Hiểm Tiêu Chuẩn Quốc Gia</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="font-size:14px; color:var(--text-secondary); line-height:1.8; text-align:justify; max-height:60vh; overflow-y:auto; padding:32px;" id="printableContract">
                <div class="text-center" style="margin-bottom:16px;">
                    <h4 style="font-weight:700; color:var(--text-primary); margin-bottom:4px;">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
                    <h5 style="font-weight:600; margin-bottom:8px;">Độc lập - Tự do - Hạnh phúc</h5>
                </div>
                
                <h5 style="text-align:center; font-weight:700; color:var(--text-primary); margin-bottom:20px;">HỢP ĐỒNG BẢO HIỂM MÔ TÔ CAO CẤP</h5>
                
                <div style="margin-bottom:16px;">
                    <p style="margin-bottom:12px;"><strong>Thông tin người được bảo hiểm:</strong></p>
                    <p style="margin-bottom:6px;">Họ và tên: <strong>@User.Identity?.Name</strong></p>
                    <p style="margin-bottom:6px;">Ngày bắt đầu: <strong>@DateTime.Now.ToString("dd/MM/yyyy")</strong></p>
                    <p style="margin-bottom:6px;">Ngày hết hạn: <strong>@DateTime.Now.AddYears(1).ToString("dd/MM/yyyy")</strong></p>
                    <p style="margin-bottom:12px;">Số hợp đồng: <strong>BH-@DateTime.Now.ToString("yyyyMMdd")-@(new Random().Next(1000, 9999))</strong></p>
                </div>
                
                <p style="margin-bottom:12px;"><strong>Điều 1: Đối tượng bảo hiểm</strong></p>
                <p style="margin-bottom:12px;">Bảo hiểm này áp dụng cho xe mô tô phân khối lớn do H-D Rental cung cấp, bao gồm bảo hiểm trách nhiệm dân sự bắt buộc và bảo hiểm thân vỏ tự nguyện (trong trường hợp khách hàng mua gói cao cấp).</p>
                
                <p style="margin-bottom:12px;"><strong>Điều 2: Phạm vi bồi thường</strong></p>
                <p style="margin-bottom:6px;">Công ty bảo hiểm sẽ bồi thường cho Chủ xe những thiệt hại vật chất xe xảy ra do:</p>
                <ul style="padding-left:20px; margin-bottom:12px;">
                    <li style="margin-bottom:4px;">Tai nạn bất ngờ, ngoài sự kiểm soát của chủ xe như đâm va, lật đổ.</li>
                    <li style="margin-bottom:4px;">Cháy, nổ, hỏa hoạn do nguyên nhân kỹ thuật hoặc khách quan.</li>
                    <li style="margin-bottom:4px;">Mất cắp toàn bộ xe (yêu cầu có xác nhận của cơ quan công an).</li>
                </ul>
                
                <p style="margin-bottom:12px;"><strong>Điều 3: Các điểm loại trừ bảo hiểm</strong></p>
                <p style="margin-bottom:6px;">Công ty bảo hiểm không chịu trách nhiệm bồi thường trong các trường hợp:</p>
                <ul style="padding-left:20px; margin-bottom:12px;">
                    <li style="margin-bottom:4px;">Hành vi cố ý gây thiệt hại của Chủ xe, lái xe.</li>
                    <li style="margin-bottom:4px;">Lái xe không có Giấy phép lái xe hợp lệ hoặc lái xe trong tình trạng say xỉn, sử dụng ma túy.</li>
                    <li style="margin-bottom:4px;">Thiệt hại do xe tham gia đua xe (kể cả trái phép và hợp pháp) không thông báo trước.</li>
                </ul>
                
                <p style="margin-bottom:12px;"><strong>Điều 4: Nghĩa vụ của bên mua bảo hiểm</strong></p>
                <p style="margin-bottom:16px;">Khi xảy ra sự cố, bên mua bảo hiểm phải thông báo ngay cho tổng đài cứu hộ của H-D Rental trong vòng 24 giờ và phối hợp thực hiện các thủ tục giám định thiệt hại.</p>
                
                <div style="text-align:right; margin-top:8px; margin-bottom:8px; font-style:italic; font-size:12px;">
                    TP.HCM, ngày @DateTime.Now.ToString("dd/MM/yyyy")
                </div>
                
                <div class="row text-center" style="margin-top:8px;">
                    <div class="col-6">
                        <h6 style="font-weight:700; color:var(--text-primary); margin-bottom:4px;">ĐẠI DIỆN H-D RENTAL</h6>
                        <p style="font-style:italic; font-size:12px; color:var(--text-muted); margin-bottom:8px;">(Ký, ghi rõ họ tên)</p>
                        <div style="height:60px; display:flex; align-items:center; justify-content:center; margin-bottom:4px;">
                            <img src="/images/signature_admin.png" style="max-height:50px; opacity:0.6;" alt="Chữ ký" onerror="this.style.display='none'" />
                        </div>
                        <strong>Nguyễn Văn Admin</strong>
                    </div>
                    <div class="col-6">
                        <h6 style="font-weight:700; color:var(--text-primary); margin-bottom:4px;">NGƯỜI ĐƯỢC BẢO HIỂM</h6>
                        <p style="font-style:italic; font-size:12px; color:var(--text-muted); margin-bottom:8px;">(Ký, ghi rõ họ tên)</p>
                        <div style="height:60px; display:flex; align-items:center; justify-content:center; margin-bottom:4px;">
                            <span style="color:var(--accent); font-family:'Brush Script MT', cursive; font-size:24px; opacity:0.8;">Đã ký</span>
                        </div>
                        <strong>@User.Identity?.Name</strong>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top:none; justify-content:space-between;">
                <button type="button" class="btn-hd-outline" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn-hd" onclick="window.print()"><i class="fas fa-print"></i> Tải xuống PDF</button>
            </div>
        </div>
    </div>
</div>

<!-- Call Modal Animation -->
<div class="modal fade hd-modal" id="callModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="background:#1a1a1a; border:1px solid #333; border-radius:24px; color:#fff;">
            <div class="modal-body" style="text-align:center; padding:40px 20px;">
                <div style="margin-bottom:24px; position:relative; width:80px; height:80px; margin:0 auto;">
                    <div id="callPulse1" style="position:absolute; inset:0; border-radius:50%; background:rgba(232,115,26,0.2); animation:pulse 2s infinite;"></div>
                    <div id="callPulse2" style="position:absolute; inset:10px; border-radius:50%; background:rgba(232,115,26,0.4); animation:pulse 2s infinite 0.5s;"></div>
                    <img src="https://images.unsplash.com/photo-1558981285-6f0c94958bb6?w=100&q=80" style="position:absolute; inset:20px; width:40px; height:40px; border-radius:50%; object-fit:cover; z-index:2;" />
                </div>
                <h4 style="font-weight:600; font-size:18px; margin-top:24px;">Tổng đài Cứu Hộ 24/7</h4>
                <p style="color:#aaa; font-size:14px; margin-bottom:8px;" id="callStatusText">Đang kết nối...</p>
                <p style="color:#4ade80; font-size:16px; font-weight:700; margin-bottom:32px; display:none;" id="callTimer">00:00</p>
                
                <div class="d-flex justify-content-center gap-4 mb-2">
                    <div style="text-align:center; cursor:pointer;" onclick="toggleMute()">
                        <div id="btnMute" style="width:48px; height:48px; border-radius:50%; background:#333; display:flex; align-items:center; justify-content:center; margin:0 auto 8px; font-size:18px;">
                            <i class="fas fa-microphone"></i>
                        </div>
                        <span style="font-size:11px; color:#aaa;">Tắt tiếng</span>
                    </div>
                    <div style="text-align:center; cursor:pointer;">
                        <div style="width:48px; height:48px; border-radius:50%; background:#333; display:flex; align-items:center; justify-content:center; margin:0 auto 8px; font-size:18px;">
                            <i class="fas fa-th"></i>
                        </div>
                        <span style="font-size:11px; color:#aaa;">Bàn phím</span>
                    </div>
                    <div style="text-align:center; cursor:pointer;" onclick="toggleSpeaker()">
                        <div id="btnSpeaker" style="width:48px; height:48px; border-radius:50%; background:#333; display:flex; align-items:center; justify-content:center; margin:0 auto 8px; font-size:18px;">
                            <i class="fas fa-volume-up"></i>
                        </div>
                        <span style="font-size:11px; color:#aaa;">Loa ngoài</span>
                    </div>
                </div>
                
                <div style="text-align:center; margin-top:24px;">
                    <div style="cursor:pointer; width:64px; height:64px; border-radius:50%; background:#ef4444; display:flex; align-items:center; justify-content:center; margin:0 auto; font-size:24px; box-shadow:0 4px 12px rgba(239,68,68,0.4);" onclick="endCall()" data-bs-dismiss="modal">
                        <i class="fas fa-phone-slash" style="color:#fff; transform:rotate(135deg);"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            /* Reset toàn bộ trang về nền trắng */
            html, body {
                background: white !important;
                background-color: white !important;
                color: black !important;
                margin: 0 !important;
                padding: 0 !important;
            }
            
            /* Ẩn tất cả elements */
            body * {
                visibility: hidden;
                background: transparent !important;
                background-color: transparent !important;
                box-shadow: none !important;
            }
            
            /* Chỉ hiện nội dung hợp đồng */
            #printableContract, #printableContract * {
                visibility: visible;
                color: black !important;
            }
            
            /* Reset các thẻ modal cha để không bị khoảng trắng do transform/margin của Bootstrap */
            .modal, .modal-dialog, .modal-content {
                position: static !important;
                transform: none !important;
                margin: 0 !important;
                padding: 0 !important;
                border: none !important;
                box-shadow: none !important;
            }

            #printableContract {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                height: auto;
                background: white !important;
                background-color: white !important;
                overflow: visible !important;
                max-height: none !important;
                padding: 10px 30px !important;
                margin: 0 !important;
                font-size: 12px !important;
                line-height: 1.6 !important;
            }

            /* Fix Bootstrap grid khi in - dùng flexbox thay float */
            #printableContract .row {
                display: flex !important;
                flex-direction: row !important;
                flex-wrap: nowrap !important;
                width: 100% !important;
                page-break-inside: avoid !important;
                break-inside: avoid !important;
            }

            #printableContract .col-6 {
                flex: 0 0 50% !important;
                max-width: 50% !important;
                width: 50% !important;
                box-sizing: border-box !important;
            }

            /* Ép khối chữ ký không bị tách trang */
            #printableContract .row.text-center {
                page-break-before: avoid !important;
                break-before: avoid !important;
                page-break-inside: avoid !important;
                break-inside: avoid !important;
                margin-top: 8px !important;
            }

            #printableContract .row.text-center h6 {
                font-size: 12px !important;
                margin-bottom: 4px !important;
            }

            #printableContract .row.text-center div[style*="height:80px"] {
                height: 50px !important;
                margin-bottom: 4px !important;
            }
            
            /* Ẩn các phần không cần in */
            .modal-backdrop,
            .modal-header,
            .modal-footer,
            .btn, button,
            .hd-sidebar,
            .hd-topbar,
            .hd-footer,
            header, nav, footer {
                display: none !important;
                visibility: hidden !important;
            }
            
            #printableContract h4,
            #printableContract h5,
            #printableContract h6 {
                color: black !important;
            }
            
            #printableContract p {
                margin-bottom: 8px !important;
                page-break-inside: avoid;
                color: black !important;
            }
            
            #printableContract ul {
                margin-bottom: 8px !important;
                color: black !important;
            }
            
            #printableContract li {
                margin-bottom: 2px !important;
                color: black !important;
            }
            
            #printableContract strong {
                color: black !important;
            }

            /* Ngắt trang hợp lý */
            @@page {
                margin: 15mm;
                background: white;
            }
        }
    </style>
    <script>
        let callTimerInterval;
        let seconds = 0;
        let isMuted = false;
        let isSpeakerOn = false;

        function startCallAnimation() {
            document.getElementById('callStatusText').style.display = 'block';
            document.getElementById('callStatusText').textContent = 'Đang kết nối...';
            document.getElementById('callTimer').style.display = 'none';
            document.getElementById('callPulse1').style.animation = 'pulse 2s infinite';
            document.getElementById('callPulse2').style.animation = 'pulse 2s infinite 0.5s';
            
            clearInterval(callTimerInterval);
            seconds = 0;
            
            setTimeout(() => {
                document.getElementById('callStatusText').style.display = 'none';
                document.getElementById('callTimer').style.display = 'block';
                document.getElementById('callTimer').textContent = '00:00';
                
                // Change pulse colors to green to indicate connected
                document.getElementById('callPulse1').style.background = 'rgba(74,222,128,0.2)';
                document.getElementById('callPulse2').style.background = 'rgba(74,222,128,0.4)';
                
                callTimerInterval = setInterval(() => {
                    seconds++;
                    let m = Math.floor(seconds / 60);
                    let s = seconds % 60;
                    document.getElementById('callTimer').textContent = 
                        (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
                }, 1000);
            }, 3000); // Connect after 3 seconds
        }

        function endCall() {
            clearInterval(callTimerInterval);
            document.getElementById('callStatusText').style.display = 'block';
            document.getElementById('callStatusText').textContent = 'Cuộc gọi đã kết thúc';
            document.getElementById('callTimer').style.display = 'none';
            document.getElementById('callPulse1').style.animation = 'none';
            document.getElementById('callPulse2').style.animation = 'none';
            document.getElementById('callPulse1').style.background = 'rgba(232,115,26,0.2)';
            document.getElementById('callPulse2').style.background = 'rgba(232,115,26,0.4)';
        }

        function toggleMute() {
            isMuted = !isMuted;
            const btn = document.getElementById('btnMute');
            if (isMuted) {
                btn.style.background = '#fff';
                btn.style.color = '#333';
                btn.innerHTML = '<i class="fas fa-microphone-slash"></i>';
            } else {
                btn.style.background = '#333';
                btn.style.color = '#fff';
                btn.innerHTML = '<i class="fas fa-microphone"></i>';
            }
        }

        function toggleSpeaker() {
            isSpeakerOn = !isSpeakerOn;
            const btn = document.getElementById('btnSpeaker');
            if (isSpeakerOn) {
                btn.style.background = '#fff';
                btn.style.color = '#333';
            } else {
                btn.style.background = '#333';
                btn.style.color = '#fff';
            }
        }

        function submitClaim() {
            const loaiSuCo = document.querySelector('select').value;
            const desc = document.querySelector('textarea').value;
            const images = document.getElementById('claimImages').files;
            
            if(!desc.trim()) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Thiếu thông tin',
                    text: 'Vui lòng nhập mô tả sự cố.',
                    confirmButtonText: 'Đã hiểu'
                });
                return;
            }

            // Convert images to base64
            const readFiles = Array.from(images).map(file => new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = e => resolve(e.target.result);
                reader.onerror = reject;
                reader.readAsDataURL(file);
            }));

            Promise.all(readFiles).then(base64Images => {
                const now = new Date();
                const claimId = 'CLM-' + now.getTime();
                const claim = {
                    id: claimId,
                    loaiSuCo: loaiSuCo,
                    moTa: desc,
                    soAnh: images.length,
                    anhHienTruong: base64Images,
                    trangThai: 'ChoXacNhan',
                    ngayTao: now.toISOString(),
                    nguoiDung: '@User.Identity?.Name' || 'Khách hàng'
                };

                let claims = JSON.parse(localStorage.getItem('insuranceClaims') || '[]');
                claims.unshift(claim);
                localStorage.setItem('insuranceClaims', JSON.stringify(claims));

                Swal.fire({
                    icon: 'success',
                    title: 'Đã gửi yêu cầu thành công!',
                    html: 'Hệ thống đã ghi nhận yêu cầu của bạn.<br>Nhân viên của H-D Rental sẽ liên hệ với bạn trong thời gian sớm nhất để hướng dẫn các bước tiếp theo.',
                    confirmButtonText: 'Đóng'
                }).then(() => {
                    document.querySelector('select').selectedIndex = 0;
                    document.querySelector('textarea').value = '';
                    document.getElementById('claimImages').value = '';
                    document.getElementById('agreeCheckbox').checked = false;
                    document.getElementById('btnSubmitClaim').disabled = true;
                    document.getElementById('btnSubmitClaim').style.opacity = '0.5';
                    document.getElementById('btnSubmitClaim').style.cursor = 'not-allowed';
                    loadClaimHistory();
                });
            });
        }
        
        function loadClaimHistory() {
            const claims = JSON.parse(localStorage.getItem('insuranceClaims') || '[]');
            const container = document.getElementById('claimHistoryContainer');
            
            if (claims.length === 0) {
                container.innerHTML = `
                    <div class="hd-empty-state" style="padding:40px;">
                        <div style="font-size:48px; color:var(--text-muted); margin-bottom:16px;"><i class="fas fa-clipboard-check"></i></div>
                        <h5 style="font-size:16px; font-weight:600;">Chưa có yêu cầu nào</h5>
                        <p style="font-size:13px; color:var(--text-secondary);">Bạn chưa ghi nhận bất kỳ sự cố hay yêu cầu bồi thường nào. Lịch sử các hồ sơ claim sẽ hiển thị tại đây.</p>
                    </div>
                `;
                return;
            }
            
            let html = '';
            claims.forEach(claim => {
                const statusColors = {
                    'ChoXacNhan': { bg: '#fbbf24', text: '#000', label: 'CHỜ XÁC NHẬN' },
                    'HoanThanh': { bg: '#4ade80', text: '#000', label: 'HOÀN THÀNH' },
                    'DaHuy': { bg: '#f87171', text: '#fff', label: 'ĐÃ HỦY' }
                };
                const status = statusColors[claim.trangThai];
                const date = new Date(claim.ngayTao);
                const timeAgo = getTimeAgo(date);
                
                html += `
                    <div style="border:1px solid var(--border-color); border-radius:8px; padding:16px; margin-bottom:12px; cursor:pointer; transition:0.2s;" 
                         onmouseover="this.style.borderColor='var(--accent)'" 
                         onmouseout="this.style.borderColor='var(--border-color)'"
                         onclick="viewClaimDetail('${claim.id}')">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <strong style="color:var(--text-primary);">${claim.id}</strong>
                                <span style="background:${status.bg}; color:${status.text}; padding:2px 8px; border-radius:4px; font-size:10px; font-weight:600; margin-left:8px;">${status.label}</span>
                            </div>
                            <span style="font-size:11px; color:var(--text-muted);">${timeAgo}</span>
                        </div>
                        <div style="font-size:13px; color:var(--text-secondary); margin-bottom:4px;">
                            <strong>Loại sự cố:</strong> ${claim.loaiSuCo}
                        </div>
                        <div style="font-size:13px; color:var(--text-secondary);">
                            <strong>Mô tả:</strong> ${claim.moTa.substring(0, 50)}${claim.moTa.length > 50 ? '...' : ''}
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
        }
        
        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return 'Vừa xong';
            const minutes = Math.floor(seconds / 60);
            if (minutes < 60) return minutes + ' phút trước';
            const hours = Math.floor(minutes / 60);
            if (hours < 24) return hours + ' giờ trước';
            const days = Math.floor(hours / 24);
            return days + ' ngày trước';
        }
        
        function buildPhotoGrid(photos) {
            if (!photos || photos.length === 0) return '';
            const MAX_SHOW = 5;
            const shown = photos.slice(0, MAX_SHOW);
            const extra = photos.length - MAX_SHOW;
            const count = shown.length;

            // Layout classes based on count (Facebook-style)
            const gridStyles = {
                1: [{ flex: '0 0 100%', height: '220px' }],
                2: [{ flex: '0 0 calc(50% - 2px)', height: '200px' }, { flex: '0 0 calc(50% - 2px)', height: '200px' }],
                3: [{ flex: '0 0 calc(50% - 2px)', height: '200px', gridRow: 'span 2' }, { flex: '0 0 calc(50% - 2px)', height: '98px' }, { flex: '0 0 calc(50% - 2px)', height: '98px' }],
                4: [{ flex: '0 0 calc(50% - 2px)', height: '130px' }, { flex: '0 0 calc(50% - 2px)', height: '130px' }, { flex: '0 0 calc(50% - 2px)', height: '130px' }, { flex: '0 0 calc(50% - 2px)', height: '130px' }],
                5: [{ flex: '0 0 calc(33.33% - 3px)', height: '130px' }, { flex: '0 0 calc(33.33% - 3px)', height: '130px' }, { flex: '0 0 calc(33.33% - 3px)', height: '130px' }, { flex: '0 0 calc(50% - 2px)', height: '130px' }, { flex: '0 0 calc(50% - 2px)', height: '130px' }]
            };

            const styles = gridStyles[Math.min(count, 5)];

            let cells = shown.map((src, i) => {
                const isLast = i === shown.length - 1 && extra > 0;
                const s = styles[i] || styles[styles.length - 1];
                return `<div onclick="openLightbox(${i}, '${encodeURIComponent(JSON.stringify(photos))}')" style="
                    flex: ${s.flex}; height: ${s.height}; position: relative; overflow: hidden; cursor: pointer;
                    background: #111; border-radius: 4px;
                ">
                    <img src="${src}" style="width:100%; height:100%; object-fit:cover; display:block; transition: transform 0.2s;"
                         onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'"/>
                    ${isLast ? `<div onclick="event.stopPropagation(); openLightbox(${MAX_SHOW}, '${encodeURIComponent(JSON.stringify(photos))}')" style="
                        position:absolute; inset:0; background:rgba(0,0,0,0.55);
                        display:flex; align-items:center; justify-content:center;
                        font-size:28px; font-weight:700; color:#fff; cursor:pointer;
                    ">+${extra}</div>` : ''}
                </div>`;
            }).join('');

            return `<div style="margin-top:8px;">
                <strong style="color:var(--text-secondary); font-size:13px; display:block; margin-bottom:8px;">Ảnh hiện trường:</strong>
                <div style="display:flex; flex-wrap:wrap; gap:4px; border-radius:8px; overflow:hidden;">${cells}</div>
            </div>`;
        }

        function openLightbox(startIndex, encodedPhotos) {
            const photos = JSON.parse(decodeURIComponent(encodedPhotos));
            let current = startIndex;

            const overlay = document.createElement('div');
            overlay.id = 'hdLightbox';
            overlay.style.cssText = `position:fixed; inset:0; background:rgba(0,0,0,0.92); z-index:99999;
                display:flex; align-items:center; justify-content:center; flex-direction:column;`;

            function render() {
                overlay.innerHTML = `
                    <div style="position:relative; max-width:90vw; max-height:80vh; display:flex; align-items:center; justify-content:center;">
                        <img src="${photos[current]}" style="max-width:90vw; max-height:78vh; object-fit:contain; border-radius:8px; box-shadow:0 8px 40px rgba(0,0,0,0.6);" />
                        ${photos.length > 1 ? `
                        <button onclick="lbPrev()" style="position:absolute; left:-56px; top:50%; transform:translateY(-50%);
                            background:rgba(255,255,255,0.15); border:none; color:#fff; width:44px; height:44px;
                            border-radius:50%; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center;">&#8249;</button>
                        <button onclick="lbNext()" style="position:absolute; right:-56px; top:50%; transform:translateY(-50%);
                            background:rgba(255,255,255,0.15); border:none; color:#fff; width:44px; height:44px;
                            border-radius:50%; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center;">&#8250;</button>
                        ` : ''}
                    </div>
                    <div style="color:rgba(255,255,255,0.6); font-size:13px; margin-top:14px;">${current + 1} / ${photos.length}</div>
                    <div style="display:flex; gap:6px; margin-top:12px; flex-wrap:wrap; justify-content:center; max-width:80vw;">
                        ${photos.map((p, i) => `<img src="${p}" onclick="lbGoto(${i})" style="
                            width:48px; height:48px; object-fit:cover; border-radius:4px; cursor:pointer;
                            border: 2px solid ${i === current ? 'var(--accent, #e8731a)' : 'transparent'};
                            opacity: ${i === current ? '1' : '0.55'}; transition:0.15s;
                        "/>`).join('')}
                    </div>
                    <button onclick="closeLightbox()" style="position:fixed; top:20px; right:24px;
                        background:rgba(255,255,255,0.15); border:none; color:#fff; width:40px; height:40px;
                        border-radius:50%; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center;">✕</button>
                `;
            }

            window.lbPrev = () => { current = (current - 1 + photos.length) % photos.length; render(); };
            window.lbNext = () => { current = (current + 1) % photos.length; render(); };
            window.lbGoto = (i) => { current = i; render(); };
            window.closeLightbox = () => { overlay.remove(); };

            overlay.addEventListener('click', e => { if (e.target === overlay) closeLightbox(); });
            document.addEventListener('keydown', function lbKey(e) {
                if (e.key === 'ArrowLeft') lbPrev();
                if (e.key === 'ArrowRight') lbNext();
                if (e.key === 'Escape') { closeLightbox(); document.removeEventListener('keydown', lbKey); }
            });

            document.body.appendChild(overlay);
            render();
        }

        function viewClaimDetail(claimId) {
            const claims = JSON.parse(localStorage.getItem('insuranceClaims') || '[]');
            const claim = claims.find(c => c.id === claimId);
            if (!claim) return;
            
            const statusLabels = {
                'ChoXacNhan': 'Chờ xác nhận',
                'HoanThanh': 'Hoàn thành',
                'DaHuy': 'Đã hủy'
            };
            const statusColors = {
                'ChoXacNhan': { bg: '#fbbf24', text: '#000' },
                'HoanThanh': { bg: '#4ade80', text: '#000' },
                'DaHuy': { bg: '#f87171', text: '#fff' }
            };
            const sc = statusColors[claim.trangThai];
            const date = new Date(claim.ngayTao);
            const formattedDate = date.toLocaleString('vi-VN');
            const photoGrid = buildPhotoGrid(claim.anhHienTruong || []);

            Swal.fire({
                title: 'Chi tiết yêu cầu bồi thường',
                html: `
                    <div style="text-align:left; padding:4px 12px 12px;">
                        <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
                            <span style="font-size:15px; font-weight:700; color:var(--accent, #e8731a);">${claim.id}</span>
                            <span style="background:${sc.bg}; color:${sc.text}; padding:2px 10px; border-radius:20px; font-size:11px; font-weight:700;">${statusLabels[claim.trangThai]}</span>
                        </div>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px;">
                            <div>
                                <div style="font-size:11px; text-transform:uppercase; color:#888; margin-bottom:3px;">Loại sự cố</div>
                                <div style="font-size:14px; font-weight:600;">${claim.loaiSuCo}</div>
                            </div>
                            <div>
                                <div style="font-size:11px; text-transform:uppercase; color:#888; margin-bottom:3px;">Ngày tạo</div>
                                <div style="font-size:13px;">${formattedDate}</div>
                            </div>
                        </div>
                        <div style="margin-bottom:14px;">
                            <div style="font-size:11px; text-transform:uppercase; color:#888; margin-bottom:3px;">Mô tả</div>
                            <div style="font-size:14px; line-height:1.6; background:rgba(255,255,255,0.04); border-radius:6px; padding:10px;">${claim.moTa}</div>
                        </div>
                        ${photoGrid}
                        ${(!claim.anhHienTruong || claim.anhHienTruong.length === 0) ? `<div style="font-size:13px; color:#666; margin-top:8px;"><i class="fas fa-image"></i> Không có ảnh đính kèm</div>` : ''}
                    </div>
                `,
                confirmButtonText: 'Đóng',
                width: '620px',
                customClass: { popup: 'swal-claim-detail' }
            });
        }
        
        // Load history on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadClaimHistory();
        });
    </script>
}
