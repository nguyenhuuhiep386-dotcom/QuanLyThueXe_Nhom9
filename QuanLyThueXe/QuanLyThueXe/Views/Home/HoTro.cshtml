@{
    ViewData["Title"] = "Hỗ trợ";
}

<!-- Hero Banner -->
<div style="position:relative; border-radius:var(--border-radius); overflow:hidden; height:180px; margin-bottom:32px; background:linear-gradient(135deg, #1a1a2e, #2a2a3e);">
    <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=800&q=80"
         style="width:100%; height:100%; object-fit:cover; opacity:0.3;" alt="Support"
         onerror="this.style.display='none'" />
    <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center;">
        <h1 style="font-size:28px; font-weight:700; font-style:italic;">Hỗ Trợ Khách Hàng 24/7</h1>
        <p style="font-size:14px; color:var(--text-secondary); margin:8px 0 16px;">Chúng tôi ở đây để giúp hành trình của bạn không bị gián đoạn.</p>
        <div class="input-group" style="max-width:480px;">
            <span class="input-group-text"><i class="fas fa-search"></i></span>
            <input type="text" id="searchFaqInput" class="form-control" placeholder="Bạn cần tìm kiếm điều gì?" style="font-size:13px;" onkeyup="if(event.key==='Enter') searchFaq()" />
            <button class="btn-hd" style="padding:8px 20px;" onclick="searchFaq()">Tìm kiếm</button>
        </div>
    </div>
</div>

<!-- Categories -->
<h3 style="font-size:20px; font-weight:700; font-style:italic; margin-bottom:20px;">Danh mục phổ biến</h3>
<div class="row g-3 mb-5">
    <!-- Thuê xe & Đặt trước -->
    <div class="col-md-6">
        <a href="@Url.Action("DanhSach", "Xe")" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-motorcycle" style="color:#e8731a;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Thuê xe & Đặt trước</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Quy trình, điều kiện, và quản lý chuyến đi.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>

    <!-- Bảo hiểm & Pháp lý -->
    <div class="col-md-6">
        <a href="@Url.Action("BaoHiem", "Home")" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-shield-alt" style="color:#fbbf24;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Bảo hiểm & Pháp lý</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Chính sách bảo hiểm, trách nhiệm bồi thường.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>

    <!-- Thanh toán -->
    <div class="col-md-6">
        <a href="#" onclick="showPaymentFAQ(); return false;" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-credit-card" style="color:#4ade80;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Thanh toán</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Hóa đơn, phương thức thanh toán, hoàn tiền.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>

    <!-- Hỗ trợ kỹ thuật -->
    <div class="col-md-6">
        <a href="#" onclick="showRescueModal(); return false;" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-wrench" style="color:#60a5fa;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Hỗ trợ kỹ thuật</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Xử lý sự cố trên đường, hướng dẫn vận hành.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>
</div>

<!-- FAQ -->
<h3 style="font-size:20px; font-weight:700; font-style:italic; margin-bottom:20px;">Câu hỏi thường gặp</h3>
<div class="mb-5 accordion" id="faqAccordion">
    @{
        var faqs = new[] {
            new { Id = "faq1", Q = "Tôi cần những giấy tờ gì để thuê xe?", A = "Bạn cần CCCD/CMND còn hiệu lực và Giấy phép lái xe hạng A2 trở lên. Đối với khách quốc tế, cần hộ chiếu và bằng lái quốc tế." },
            new { Id = "faq2", Q = "Chính sách hủy đặt xe như thế nào?", A = "Hủy trước 48 giờ: hoàn 100% tiền cọc. Hủy trước 24 giờ: hoàn 50%. Hủy trong vòng 24 giờ: không hoàn tiền cọc." },
            new { Id = "faq3", Q = "Làm sao để hoàn tiền?", A = "Để yêu cầu hoàn tiền, vui lòng làm theo các bước sau:<br><ol style='margin-top:8px; padding-left:20px;'><li>Đăng nhập vào tài khoản và truy cập phần <strong>Đơn hàng của tôi</strong>.</li><li>Chọn đơn hàng muốn hủy và nhấn <strong>Yêu cầu hủy & Hoàn tiền</strong>.</li><li>Điền lý do và xác nhận.</li><li>Tiền sẽ được hoàn về tài khoản của bạn trong vòng 3-5 ngày làm việc.</li></ol>" },
            new { Id = "faq4", Q = "Tôi có thể gia hạn thuê xe không?", A = "Có, bạn có thể gia hạn thuê xe trực tiếp trên ứng dụng hoặc liên hệ hotline. Phí gia hạn tính theo giá thuê ngày hiện tại." }
        };
    }
    @foreach (var faq in faqs)
    {
        <div class="accordion-item" style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); margin-bottom:12px; overflow:hidden;">
            <h2 class="accordion-header" id="heading-@faq.Id">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@faq.Id" aria-expanded="false" aria-controls="collapse-@faq.Id" style="background:transparent; color:var(--text-primary); box-shadow:none; font-size:14px; font-weight:600; padding:20px;">
                    @faq.Q
                </button>
            </h2>
            <div id="collapse-@faq.Id" class="accordion-collapse collapse" aria-labelledby="heading-@faq.Id" data-bs-parent="#faqAccordion">
                <div class="accordion-body" style="padding:0 20px 20px; font-size:13px; color:var(--text-secondary);">
                    @Html.Raw(faq.A)
                </div>
            </div>
        </div>
    }
</div>

<!-- Emergency Hotline -->
<div style="background:linear-gradient(135deg, #2a1508, #3a2010); border:1px solid rgba(232,115,26,0.3); border-radius:var(--border-radius); padding:24px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
    <div class="d-flex gap-3 align-items-center">
        <div style="width:48px; height:48px; background:var(--accent); border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-phone-alt" style="font-size:20px;"></i>
        </div>
        <div>
            <h4 style="font-size:18px; font-weight:700; margin-bottom:2px;">Đường Dây Nóng Khẩn Cấp 24/7</h4>
            <p style="font-size:13px; color:var(--text-secondary); margin:0;">Hỗ trợ tai nạn, hỏng hóc nghiêm trọng trên đường.</p>
        </div>
    </div>
    <div style="display:flex; align-items:center; gap:12px;">
        <button class="btn-hd" style="padding:12px 24px; font-size:16px; font-weight:700; position:relative; overflow:hidden;" data-bs-toggle="modal" data-bs-target="#callModal" onclick="startCallAnimation()">
            <div id="btnPulse1" style="position:absolute; inset:0; border-radius:8px; background:rgba(255,255,255,0.2); animation:pulse 2s infinite;"></div>
            <i class="fas fa-phone-alt"></i> &nbsp;GỌI CỨU HỘ NGAY
        </button>
    </div>
</div>

<!-- Call Modal Animation -->
<div class="modal fade hd-modal" id="callModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="background:#1a1a1a; border:1px solid #333; border-radius:24px; color:#fff;">
            <div class="modal-body" style="text-align:center; padding:40px 20px;">
                <div style="margin-bottom:24px; position:relative; width:80px; height:80px; margin:0 auto;">
                    <div id="callPulse1" style="position:absolute; inset:0; border-radius:50%; background:rgba(232,115,26,0.2); animation:pulse 2s infinite;"></div>
                    <div id="callPulse2" style="position:absolute; inset:10px; border-radius:50%; background:rgba(232,115,26,0.4); animation:pulse 2s infinite 0.5s;"></div>
                    <div style="position:absolute; inset:20px; width:40px; height:40px; border-radius:50%; background:var(--accent); display:flex; align-items:center; justify-content:center; z-index:2;">
                        <i class="fas fa-headset" style="color:#fff; font-size:20px;"></i>
                    </div>
                </div>
                <h4 style="font-weight:600; font-size:18px; margin-top:24px;">Tổng đài Cứu Hộ 24/7</h4>
                <p style="color:#aaa; font-size:14px; margin-bottom:8px;" id="callStatusText">Đang kết nối...</p>
                <p style="color:#4ade80; font-size:16px; font-weight:700; margin-bottom:32px; display:none;" id="callTimer">00:00</p>
                
                <div class="d-flex justify-content-center gap-4 mb-2">
                    <div style="text-align:center; cursor:pointer;" onclick="toggleMute()">
                        <div id="btnMute" style="width:48px; height:48px; border-radius:50%; background:#333; display:flex; align-items:center; justify-content:center; margin:0 auto 8px; font-size:18px;">
                            <i class="fas fa-microphone"></i>
                        </div>
                        <span style="font-size:11px; color:#aaa;">Tắt tiếng</span>
                    </div>
                    <div style="text-align:center; cursor:pointer;" onclick="toggleSpeaker()">
                        <div id="btnSpeaker" style="width:48px; height:48px; border-radius:50%; background:#333; display:flex; align-items:center; justify-content:center; margin:0 auto 8px; font-size:18px;">
                            <i class="fas fa-volume-up"></i>
                        </div>
                        <span style="font-size:11px; color:#aaa;">Loa ngoài</span>
                    </div>
                </div>
                
                <div style="text-align:center; margin-top:24px;">
                    <div style="cursor:pointer; width:64px; height:64px; border-radius:50%; background:#ef4444; display:flex; align-items:center; justify-content:center; margin:0 auto; font-size:24px; box-shadow:0 4px 12px rgba(239,68,68,0.4);" onclick="endCall()" data-bs-dismiss="modal">
                        <i class="fas fa-phone-slash" style="color:#fff; transform:rotate(135deg);"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payment FAQ Modal -->
<div class="modal fade hd-modal" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:12px;">
            <div class="modal-header" style="border-bottom:1px solid var(--border-color);">
                <h5 class="modal-title" style="font-weight:700; font-size:18px;"><i class="fas fa-credit-card" style="color:var(--accent);"></i> Hướng dẫn Thanh toán</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="font-size:14px; color:var(--text-secondary); line-height:1.8; max-height:60vh; overflow-y:auto; padding:32px;">
                <h4 style="color:var(--text-primary); margin-bottom:16px; font-weight:700; font-size:16px;">1. Cách tính hóa đơn</h4>
                <p style="margin-bottom:16px;">Tổng tiền thuê xe được tính theo công thức:</p>
                <div style="background:rgba(232,115,26,0.1); border-left:4px solid var(--accent); padding:16px; margin-bottom:16px; border-radius:4px;">
                    <strong>Tổng tiền = (Giá thuê/ngày × Số ngày × Hệ số mùa) + Phí bảo hiểm - Giảm giá</strong>
                </div>
                <ul style="padding-left:20px; margin-bottom:24px;">
                    <li style="margin-bottom:8px;"><strong>Giá thuê/ngày:</strong> Giá cơ bản của từng loại xe</li>
                    <li style="margin-bottom:8px;"><strong>Hệ số mùa:</strong> Áp dụng trong các dịp lễ, Tết (thường x1.2 - x1.5)</li>
                    <li style="margin-bottom:8px;"><strong>Phí bảo hiểm:</strong> Tùy chọn (Cơ bản: miễn phí, Cao cấp: 1,000,000đ)</li>
                    <li style="margin-bottom:8px;"><strong>Giảm giá:</strong> Từ mã khuyến mãi (nếu có)</li>
                </ul>

                <h4 style="color:var(--text-primary); margin:24px 0 16px; font-weight:700; font-size:16px;">2. Các phương thức thanh toán</h4>
                <div class="row g-3 mb-24">
                    <div class="col-md-6">
                        <div style="border:1px solid var(--border-color); border-radius:8px; padding:16px;">
                            <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
                                <i class="fas fa-credit-card" style="font-size:24px; color:var(--accent);"></i>
                                <strong>Thẻ tín dụng/Ghi nợ</strong>
                            </div>
                            <p style="font-size:13px; margin:0;">Visa, Mastercard, JCB. Thanh toán ngay lập tức, an toàn với mã hóa SSL.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div style="border:1px solid var(--border-color); border-radius:8px; padding:16px;">
                            <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
                                <i class="fas fa-university" style="font-size:24px; color:#4ade80;"></i>
                                <strong>Chuyển khoản ngân hàng</strong>
                            </div>
                            <p style="font-size:13px; margin:0;">Chuyển khoản qua QR Code hoặc số tài khoản. Xác nhận trong 5-10 phút.</p>
                        </div>
                    </div>
                </div>

                <h4 style="color:var(--text-primary); margin:24px 0 16px; font-weight:700; font-size:16px;">3. Chính sách tiền cọc</h4>
                <p style="margin-bottom:16px;">Khi đặt xe, bạn cần thanh toán <strong style="color:var(--accent);">30% tổng giá trị hợp đồng</strong> làm tiền đặt cọc.</p>
                <ul style="padding-left:20px; margin-bottom:24px;">
                    <li style="margin-bottom:8px;">Tiền cọc được giữ để đảm bảo cam kết thuê xe</li>
                    <li style="margin-bottom:8px;">Hoàn trả 100% nếu xe được trả đúng hạn, nguyên vẹn</li>
                    <li style="margin-bottom:8px;">Thời gian hoàn tiền: 3-5 ngày làm việc</li>
                </ul>

                <h4 style="color:var(--text-primary); margin:24px 0 16px; font-weight:700; font-size:16px;">4. Chi tiết hoàn tiền</h4>
                <p style="margin-bottom:16px;">Chính sách hoàn tiền khi hủy đặt xe:</p>
                <div style="background:var(--bg-dark); border-radius:8px; padding:16px; margin-bottom:16px;">
                    <div style="display:flex; justify-content:space-between; padding:12px 0; border-bottom:1px solid var(--border-color);">
                        <span>Hủy trước 48 giờ</span>
                        <strong style="color:#4ade80;">Hoàn 100%</strong>
                    </div>
                    <div style="display:flex; justify-content:space-between; padding:12px 0; border-bottom:1px solid var(--border-color);">
                        <span>Hủy trước 24 giờ</span>
                        <strong style="color:#fbbf24;">Hoàn 50%</strong>
                    </div>
                    <div style="display:flex; justify-content:space-between; padding:12px 0;">
                        <span>Hủy trong vòng 24 giờ</span>
                        <strong style="color:#f87171;">Không hoàn</strong>
                    </div>
                </div>
                <p style="font-size:13px; color:var(--text-muted); margin-bottom:24px;">
                    <i class="fas fa-info-circle"></i> Tiền sẽ được hoàn về tài khoản ngân hàng bạn đã đăng ký trong phần Cài đặt.
                </p>

                <h4 style="color:var(--text-primary); margin:24px 0 16px; font-weight:700; font-size:16px;">5. Câu hỏi thường gặp</h4>
                <div style="margin-bottom:16px;">
                    <strong style="color:var(--text-primary);">Q: Tôi có thể thanh toán bằng tiền mặt không?</strong>
                    <p style="margin:8px 0 0; padding-left:16px;">A: Hiện tại chúng tôi chỉ chấp nhận thanh toán online để đảm bảo an toàn và minh bạch.</p>
                </div>
                <div style="margin-bottom:16px;">
                    <strong style="color:var(--text-primary);">Q: Mã khuyến mãi có giảm tiền cọc không?</strong>
                    <p style="margin:8px 0 0; padding-left:16px;">A: Không. Mã khuyến mãi chỉ áp dụng cho tổng tiền thuê, không giảm tiền đặt cọc.</p>
                </div>
                <div>
                    <strong style="color:var(--text-primary);">Q: Làm sao để nhận hóa đơn VAT?</strong>
                    <p style="margin:8px 0 0; padding-left:16px;">A: Vui lòng yêu cầu xuất hóa đơn VAT trong phần Ghi chú khi đặt xe, hoặc liên hệ hotline sau khi hoàn tất chuyến đi.</p>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--border-color);">
                <button type="button" class="btn-hd w-100" data-bs-dismiss="modal">Đã hiểu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function searchFaq() {
            let term = document.getElementById('searchFaqInput').value.toLowerCase().trim();
            let items = document.querySelectorAll('.accordion-item');
            
            items.forEach(item => {
                let q = item.querySelector('.accordion-button').textContent.toLowerCase();
                let a = item.querySelector('.accordion-body').textContent.toLowerCase();
                if (q.includes(term) || a.includes(term) || term === '') {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
            
            // Tự động cuộn đến danh sách câu hỏi nếu có từ khóa
            if (term !== '') {
                document.getElementById('faqAccordion').scrollIntoView({behavior: 'smooth', block: 'center'});
            }
        }
        let callTimerInterval;
        let seconds = 0;
        let isMuted = false;
        let isSpeakerOn = false;

        function startCallAnimation() {
            document.getElementById('callStatusText').style.display = 'block';
            document.getElementById('callStatusText').textContent = 'Đang kết nối...';
            document.getElementById('callTimer').style.display = 'none';
            document.getElementById('callPulse1').style.animation = 'pulse 2s infinite';
            document.getElementById('callPulse2').style.animation = 'pulse 2s infinite 0.5s';
            
            clearInterval(callTimerInterval);
            seconds = 0;
            
            setTimeout(() => {
                document.getElementById('callStatusText').style.display = 'none';
                document.getElementById('callTimer').style.display = 'block';
                document.getElementById('callTimer').textContent = '00:00';
                
                // Change pulse colors to green to indicate connected
                document.getElementById('callPulse1').style.background = 'rgba(74,222,128,0.2)';
                document.getElementById('callPulse2').style.background = 'rgba(74,222,128,0.4)';
                
                callTimerInterval = setInterval(() => {
                    seconds++;
                    let m = Math.floor(seconds / 60);
                    let s = seconds % 60;
                    document.getElementById('callTimer').textContent = 
                        (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
                }, 1000);
            }, 3000); // Connect after 3 seconds
        }

        function endCall() {
            clearInterval(callTimerInterval);
            document.getElementById('callStatusText').style.display = 'block';
            document.getElementById('callStatusText').textContent = 'Cuộc gọi đã kết thúc';
            document.getElementById('callTimer').style.display = 'none';
            document.getElementById('callPulse1').style.animation = 'none';
            document.getElementById('callPulse2').style.animation = 'none';
            document.getElementById('callPulse1').style.background = 'rgba(232,115,26,0.2)';
            document.getElementById('callPulse2').style.background = 'rgba(232,115,26,0.4)';
        }

        function toggleMute() {
            isMuted = !isMuted;
            const btn = document.getElementById('btnMute');
            if (isMuted) {
                btn.style.background = '#fff';
                btn.style.color = '#333';
                btn.innerHTML = '<i class="fas fa-microphone-slash"></i>';
            } else {
                btn.style.background = '#333';
                btn.style.color = '#fff';
                btn.innerHTML = '<i class="fas fa-microphone"></i>';
            }
        }

        function toggleSpeaker() {
            isSpeakerOn = !isSpeakerOn;
            const btn = document.getElementById('btnSpeaker');
            if (isSpeakerOn) {
                btn.style.background = '#fff';
                btn.style.color = '#333';
            } else {
                btn.style.background = '#333';
                btn.style.color = '#fff';
            }
        }
        
        function showRescueModal() {
            var myModal = new bootstrap.Modal(document.getElementById('callModal'));
            myModal.show();
            startCallAnimation();
        }
        
        function showPaymentFAQ() {
            var myModal = new bootstrap.Modal(document.getElementById('paymentModal'));
            myModal.show();
        }
    </script>
}
