@{
    ViewData["Title"] = "Mẫu Hợp Đồng Thuê Xe";
}

<div class="hd-section-header" style="margin-bottom:24px;">
    <h1 style="font-size:28px; font-weight:700;">Mẫu Hợp Đồng Thuê Xe</h1>
</div>

<div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:32px;">
    <div style="font-size:16px; color:var(--text-secondary); line-height:2.0; text-align:justify;">
        <h3 style="text-align:center; font-weight:700; color:var(--text-primary); margin:24px 0 8px; font-size:24px;">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h3>
        <h4 style="text-align:center; font-weight:600; font-size:18px; margin-bottom:32px;">Độc lập - Tự do - Hạnh phúc</h4>
        <h2 style="text-align:center; color:var(--text-primary); margin:24px 0 40px; font-weight:700; font-size:28px;">HỢP ĐỒNG THUÊ XE MÔ TÔ</h2>

        <div style="margin-bottom:24px;">
            <p style="font-size:18px;"><strong>BÊN CHO THUÊ (BÊN A): H-D RENTAL</strong></p>
            <p style="font-size:18px;"><strong>BÊN THUÊ (BÊN B): [Thông tin khách hàng]</strong></p>
        </div>

        <h4 style="color:var(--text-primary); margin:32px 0 16px; font-weight:700; font-size:20px;">Điều 1: Đối tượng hợp đồng</h4>
        <p>Bên A đồng ý cho Bên B thuê xe mô tô theo thông tin chi tiết trên hệ thống đặt xe. Bên B có quyền sử dụng xe mô tô trong khoảng thời gian đã đăng ký và cam kết tuân thủ các điều kiện kèm theo.</p>

        <h4 style="color:var(--text-primary); margin:32px 0 16px; font-weight:700; font-size:20px;">Điều 2: Thời hạn và Giá thuê</h4>
        <p>Thời hạn thuê và giá thuê được tính theo thông tin xác nhận đặt xe trên ứng dụng. Mọi khoản phụ phí phát sinh do trả xe muộn, vi phạm hợp đồng hoặc hỏng hóc sẽ được tính theo bảng phí tiêu chuẩn của H-D Rental.</p>

        <h4 style="color:var(--text-primary); margin:32px 0 16px; font-weight:700; font-size:20px;">Điều 3: Cam kết của các bên</h4>
        <p>Bên B cam kết sử dụng xe đúng mục đích, tuân thủ nghiêm ngặt Luật Giao thông đường bộ và chịu toàn bộ trách nhiệm bảo quản xe trong suốt thời gian thuê. Bên A cam kết giao xe đúng hẹn, đúng loại xe, đảm bảo xe ở tình trạng hoạt động tốt và đầy đủ giấy tờ cần thiết.</p>
    </div>
</div>
