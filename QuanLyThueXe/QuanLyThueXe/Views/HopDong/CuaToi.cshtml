@model IEnumerable<QuanLyThueXe.Models.HopDong>

@{
    ViewData["Title"] = "Lịch đặt xe";
}

<form method="get" asp-action="CuaToi" id="filterForm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="font-size:24px; font-weight:700;">Lịch đặt xe</h2>
        <div class="d-flex gap-2 align-items-center">
            <div class="input-group" style="width:280px;">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control" placeholder="Tìm kiếm mã đơn hàng..." style="font-size:13px;" />
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mb-4 flex-wrap align-items-end">
        <div>
            <label style="font-size:11px; color:var(--text-muted); display:block; margin-bottom:4px;">Trạng thái</label>
            @{
                var currentTrangThai = Context.Request.Query["trangThai"].ToString();
            }
            <select name="trangThai" class="form-select" style="font-size:13px; width:200px;">
                <option value="">Tất cả trạng thái</option>
                <option value="ChoXacNhan" selected="@(currentTrangThai == "ChoXacNhan")">Chờ xác nhận</option>
                <option value="DaXacNhan" selected="@(currentTrangThai == "DaXacNhan")">Đã xác nhận</option>
                <option value="DangThue" selected="@(currentTrangThai == "DangThue")">Đang thuê</option>
                <option value="DaTra" selected="@(currentTrangThai == "DaTra")">Hoàn thành</option>
                <option value="DaHuy" selected="@(currentTrangThai == "DaHuy")">Đã hủy</option>
            </select>
        </div>
        <div>
            <label style="font-size:11px; color:var(--text-muted); display:block; margin-bottom:4px;">Khoảng thời gian</label>
            <select name="thoiGian" class="form-select" style="font-size:13px; width:200px;">
                <option value="30" selected="@(Context.Request.Query["thoiGian"] == "30")">30 ngày gần nhất</option>
                <option value="90" selected="@(Context.Request.Query["thoiGian"] == "90")">3 tháng gần nhất</option>
                <option value="all" selected="@(Context.Request.Query["thoiGian"] == "all")">Tất cả</option>
            </select>
        </div>
        <div>
            <button type="submit" class="btn-hd-outline" style="font-size:12px; padding:8px 16px;">
                <i class="fas fa-filter"></i> Lọc
            </button>
        </div>
    </div>
</form>

@if (Model.Any())
{
    <!-- Table -->
    <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); overflow:hidden;">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>MÃ HỢP ĐỒNG</th>
                    <th>LOẠI XE</th>
                    <th>KHOẢNG THỜI GIAN</th>
                    <th>TỔNG CHI PHÍ</th>
                    <th>TRẠNG THÁI</th>
                    <th style="text-align:center;">ĐÁNH GIÁ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hd in Model)
                {
                    var statusColor = hd.TrangThai switch {
                        "ChoXacNhan" => "color:#fbbf24; background:#3d2e0a;",
                        "DaXacNhan" => "color:#60a5fa; background:#1e3a5f;",
                        "DangThue" => "color:#4ade80; background:#0a3d1e;",
                        "DaTra" => "color:#34d399; background:#064e3b;",
                        "DaHuy" => "color:#f87171; background:#3d0a0a;",
                        _ => "color:var(--text-muted); background:var(--bg-card);"
                    };
                    var statusText = hd.TrangThai switch {
                        "ChoXacNhan" => "Chờ xác nhận",
                        "DaXacNhan" => "Đã xác nhận",
                        "DangThue" => "Đang thuê",
                        "DaTra" => "Hoàn thành",
                        "DaHuy" => "Đã hủy",
                        _ => hd.TrangThai
                    };
                    <tr style="cursor:pointer;" onclick="window.location.href='@Url.Action("ChiTiet", new { id = hd.MaHopDong })'">
                        <td><strong style="color:var(--text-primary);">#HD-@hd.MaHopDong</strong></td>
                        <td><strong style="color:var(--text-primary);">@hd.Xe.TenXe</strong></td>
                        <td style="color:var(--text-secondary);">@hd.NgayThue.ToString("dd/MM") - @hd.NgayTra.ToString("dd/MM/yyyy")</td>
                        <td style="color:var(--accent); font-weight:600;">@hd.TongTien.ToString("N0")đ</td>
                        <td>
                            <span style="@statusColor padding:4px 12px; border-radius:16px; font-size:11px; font-weight:600;">
                                @statusText
                            </span>
                        </td>
                        <td style="text-align:center;">
                            @if (hd.TrangThai == "DaTra")
                            {
                                if (hd.DanhGia != null)
                                {
                                    <div style="color:#fbbf24; font-size:12px;">
                                        @for (int i = 0; i < hd.DanhGia.SoSao; i++) { <i class="fas fa-star"></i> }
                                    </div>
                                }
                                else
                                {
                                    <a asp-action="DanhGiaTraXe" asp-route-id="@hd.MaHopDong" class="btn-hd-outline" style="padding:4px 12px; font-size:11px; color:green; font-weight:bold;" onclick="event.stopPropagation();">
                                        Đánh giá
                                    </a>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div style="padding:12px 16px; border-top:1px solid var(--border-color); display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:12px; color:var(--text-muted);">Hiển thị 1-@Model.Count() trong @Model.Count() kết quả</span>
            <div class="d-flex gap-1">
                <button class="btn-hd-outline" style="padding:4px 10px; font-size:12px;"><i class="fas fa-chevron-left"></i></button>
                <button class="btn-hd-outline" style="padding:4px 10px; font-size:12px;"><i class="fas fa-chevron-right"></i></button>
            </div>
        </div>
    </div>
}
else
{
    <!-- Empty State -->
    <div class="hd-empty-state">
        <div class="empty-icon"><i class="fas fa-motorcycle"></i></div>
        <h3 style="font-style:italic;">Bạn chưa có lịch đặt xe nào</h3>
        <p>Những cung đường huyền thoại đang chờ đợi bạn. Hãy bắt đầu hành trình chinh phục ngay hôm nay với đội xe Harley-Davidson cao cấp nhất.</p>
        <a asp-controller="Xe" asp-action="DanhSach" class="btn-hd-outline" style="font-size:14px; padding:12px 32px;">
            Khám phá đội xe
        </a>
    </div>

    <!-- Suggestions -->
    <div style="margin-top:48px;">
        <div class="hd-section-header">
            <div>
                <h3 style="font-size:20px; font-weight:600; font-style:italic;">Gợi ý dành cho bạn</h3>
                <p style="font-size:13px; color:var(--text-secondary);">Những mẫu xe được yêu thích nhất trong tuần này</p>
            </div>
            <a asp-controller="Xe" asp-action="DanhSach" class="view-all">Xem tất cả <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
}
