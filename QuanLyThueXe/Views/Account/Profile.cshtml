@model QuanLyThueXe.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="tab-content" id="v-pills-tabContent">
            <!-- Hồ sơ cá nhân Tab -->
            <div class="tab-pane fade show active" id="v-pills-profile" role="tabpanel" aria-labelledby="v-pills-profile-tab">
                <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:32px;">
                    <h2 style="font-size:20px; font-weight:700; margin-bottom:24px;">Thông tin cá nhân</h2>
                    
                    <!-- Avatar Upload Section -->
                    <div class="text-center mb-4">
                        <div class="avatar-upload">
                            <div class="avatar-preview">
                                <img src="/images/default-avatar.png" 
                                     alt="Avatar" 
                                     id="avatarPreview" 
                                     onerror="this.src='https://ui-avatars.com/api/?name=User&background=e8731a&color=fff&size=150'" />
                            </div>
                            <label for="avatarInput" class="avatar-edit">
                                <i class="fas fa-camera"></i>
                            </label>
                            <input type="file" 
                                   id="avatarInput" 
                                   accept="image/*" 
                                   style="display: none;" 
                                   onchange="previewAvatar(this)" />
                        </div>
                        <p style="font-size: 12px; color: var(--text-muted); margin-top: 12px;">
                            Nhấn vào biểu tượng camera để thay đổi ảnh đại diện
                        </p>
                    </div>
                    
                    <form asp-action="Profile" method="post" id="profileForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="HoTen" class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px;"></label>
                                <input asp-for="HoTen" class="form-control" style="background:var(--bg-dark); border:1px solid var(--border-color); color:var(--text-primary); padding:10px 16px; font-size:14px;" placeholder="Nhập họ và tên" />
                                <span asp-validation-for="HoTen" class="text-danger" style="font-size:12px;"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SoDienThoai" class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px;"></label>
                                <input asp-for="SoDienThoai" class="form-control" style="background:var(--bg-dark); border:1px solid var(--border-color); color:var(--text-primary); padding:10px 16px; font-size:14px;" placeholder="Nhập số điện thoại" />
                                <span asp-validation-for="SoDienThoai" class="text-danger" style="font-size:12px;"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Email" class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px;"></label>
                                <input asp-for="Email" class="form-control" style="background:var(--bg-dark); border:1px solid var(--border-color); color:var(--text-primary); padding:10px 16px; font-size:14px;" placeholder="Nhập địa chỉ email" />
                                <span asp-validation-for="Email" class="text-danger" style="font-size:12px;"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SoGiayTo" class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px;"></label>
                                <input asp-for="SoGiayTo" class="form-control" style="background:var(--bg-dark); border:1px solid var(--border-color); color:var(--text-primary); padding:10px 16px; font-size:14px;" placeholder="Nhập số CMND/CCCD" />
                                <span asp-validation-for="SoGiayTo" class="text-danger" style="font-size:12px;"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SoGPLX" class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px;"></label>
                                <input asp-for="SoGPLX" class="form-control" style="background:var(--bg-dark); border:1px solid var(--border-color); color:var(--text-primary); padding:10px 16px; font-size:14px;" placeholder="Nhập số Giấy Phép Lái Xe" />
                                <span asp-validation-for="SoGPLX" class="text-danger" style="font-size:12px;"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="DiaChi" class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px;"></label>
                                <textarea asp-for="DiaChi" class="form-control" rows="2" style="background:var(--bg-dark); border:1px solid var(--border-color); color:var(--text-primary); padding:10px 16px; font-size:14px;" placeholder="Nhập địa chỉ hiện tại của bạn"></textarea>
                                <span asp-validation-for="DiaChi" class="text-danger" style="font-size:12px;"></span>
                            </div>
                        </div>

                        <div class="mt-4 text-end">
                            <button type="submit" id="submitProfileBtn" class="btn-hd" style="padding:10px 24px; font-size:14px;">
                                Lưu thay đổi
                            </button>
                        </div>
                    </form>

                    <!-- Xác minh GPLX Section -->
                    <div class="card mt-4" style="background:var(--bg-secondary); border:1px solid var(--border-color);">
                        <div class="card-header" style="background:transparent; border-bottom:1px solid var(--border-color);">
                            <h5 style="margin:0; font-size:16px; font-weight:600;">
                                <i class="fas fa-id-card text-warning"></i> Xác minh Giấy phép lái xe
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase;">Số GPLX</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="gplxNumber"
                                           placeholder="Nhập số GPLX" 
                                           value="@Model.SoGPLX" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase;">Upload ảnh GPLX</label>
                                    <input type="file" 
                                           class="form-control" 
                                           id="gplxImage"
                                           accept="image/*" />
                                </div>
                            </div>
                            <div class="mt-3">
                                <button type="button" class="btn btn-warning" onclick="verifyGPLX()">
                                    <i class="fas fa-check"></i> Xác minh ngay
                                </button>
                                <small class="text-muted d-block mt-2" style="font-size:11px;">
                                    <i class="fas fa-info-circle"></i> Xác minh GPLX giúp bạn thuê xe nhanh chóng hơn
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cài đặt Tab -->
            <div class="tab-pane fade" id="v-pills-settings" role="tabpanel" aria-labelledby="v-pills-settings-tab">
                <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:32px;">
                    <h2 style="font-size:20px; font-weight:700; margin-bottom:24px;">Cài đặt tài khoản</h2>
                    
                    <div class="mb-4 pb-4" style="border-bottom:1px solid var(--border-color);">
                        <h4 style="font-size:16px; font-weight:600; margin-bottom:16px;">Đổi mật khẩu</h4>
                        <form id="settingsForm">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <input type="password" name="currentPass" class="form-control" placeholder="Mật khẩu hiện tại" style="font-size:13px;" />
                                </div>
                                <div class="col-md-4">
                                    <input type="password" name="newPass" class="form-control" placeholder="Mật khẩu mới" style="font-size:13px;" />
                                </div>
                                <div class="col-md-4">
                                    <input type="password" name="confirmPass" class="form-control" placeholder="Xác nhận mật khẩu" style="font-size:13px;" />
                                </div>
                            </div>
                            <button type="button" id="submitSettingsBtn" class="btn-hd-outline mt-3" onclick="alert('Đã cập nhật mật khẩu thành công!')" style="font-size:13px; padding:6px 16px;">Cập nhật mật khẩu</button>
                        </form>
                    </div>

                    <div>
                        <h4 style="font-size:16px; font-weight:600; margin-bottom:16px;">Thông báo</h4>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="notiEmail" checked style="cursor:pointer;">
                            <label class="form-check-label" for="notiEmail" style="font-size:14px; cursor:pointer;">Nhận thông báo qua Email</label>
                            <p style="font-size:12px; color:var(--text-muted); margin-top:4px;">Nhận các cập nhật về trạng thái hợp đồng, ưu đãi.</p>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="notiSms" checked style="cursor:pointer;">
                            <label class="form-check-label" for="notiSms" style="font-size:14px; cursor:pointer;">Nhận thông báo qua SMS</label>
                            <p style="font-size:12px; color:var(--text-muted); margin-top:4px;">Nhận tin nhắn SMS khẩn cấp liên quan đến việc nhận và trả xe.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function verifyGPLX() {
            const gplxNumber = document.getElementById('gplxNumber').value;
            const gplxImage = document.getElementById('gplxImage').files;
            
            if (!gplxNumber) {
                showToast('Vui lòng nhập số GPLX', 'warning');
                return;
            }
            
            if (gplxImage.length === 0) {
                showToast('Vui lòng upload ảnh GPLX', 'warning');
                return;
            }
            
            // Giả lập xác minh
            showToast('Đã gửi yêu cầu xác minh GPLX thành công!', 'success');
        }

        $(document).ready(function() {
            var initialProfileState = $('#profileForm').serialize();
            var $submitProfileBtn = $('#submitProfileBtn');
            $submitProfileBtn.prop('disabled', true).css('opacity', '0.5');

            $('#profileForm input, #profileForm textarea').on('input change', function() {
                if ($('#profileForm').serialize() !== initialProfileState) {
                    $submitProfileBtn.prop('disabled', false).css('opacity', '1');
                } else {
                    $submitProfileBtn.prop('disabled', true).css('opacity', '0.5');
                }
            });

            var initialSettingsState = $('#settingsForm').serialize();
            var $submitSettingsBtn = $('#submitSettingsBtn');
            $submitSettingsBtn.prop('disabled', true).css('opacity', '0.5');

            $('#settingsForm input, #settingsForm select').on('input change', function() {
                if ($('#settingsForm').serialize() !== initialSettingsState) {
                    $submitSettingsBtn.prop('disabled', false).css('opacity', '1');
                } else {
                    $submitSettingsBtn.prop('disabled', true).css('opacity', '0.5');
                }
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
