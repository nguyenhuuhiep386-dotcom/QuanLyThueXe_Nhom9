@{
    ViewData["Title"] = "Liên hệ";
}

<div class="hd-section-header" style="margin-bottom:24px;">
    <h1 style="font-size:28px; font-weight:700;">Liên hệ chúng tôi</h1>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:32px; height:100%;">
            <h4 style="font-size:18px; font-weight:600; margin-bottom:24px;">Gửi tin nhắn cho H-D Rental</h4>
            <div class="mb-3">
                <label class="form-label">CHỦ ĐỀ</label>
                <select class="form-select">
                    <option value="">-- Chọn chủ đề --</option>
                    <option value="thue_xe">Tư vấn thuê xe</option>
                    <option value="bao_hiem">Bảo hiểm & Sự cố</option>
                    <option value="hop_tac">Hợp tác kinh doanh</option>
                    <option value="gop_y">Góp ý dịch vụ</option>
                    <option value="khac">Khác</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">HỌ VÀ TÊN</label>
                <input type="text" class="form-control" placeholder="Nhập họ và tên..." />
            </div>
            <div class="mb-3">
                <label class="form-label">EMAIL</label>
                <input type="email" class="form-control" placeholder="Nhập địa chỉ email..." />
            </div>
            <div class="mb-3">
                <label class="form-label">TIN NHẮN</label>
                <textarea class="form-control" rows="4" placeholder="Nhập nội dung cần liên hệ..."></textarea>
            </div>
            <button class="btn-hd w-100" style="justify-content:center;">Gửi Tin Nhắn</button>
        </div>
    </div>
    <div class="col-md-6">
        <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:32px; height:100%;">
            <h4 style="font-size:18px; font-weight:600; margin-bottom:24px;">Thông tin liên hệ</h4>
            
            <div class="d-flex gap-3 mb-4">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-map-marker-alt" style="color:var(--accent);"></i>
                </div>
                <div>
                    <h5 style="font-size:14px; font-weight:600; margin-bottom:4px; color:var(--text-primary);">Địa chỉ</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">123 Đường Harley, Quận 1, TP. Hồ Chí Minh</p>
                </div>
            </div>

            <div class="d-flex gap-3 mb-4">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-phone-alt" style="color:var(--accent);"></i>
                </div>
                <div>
                    <h5 style="font-size:14px; font-weight:600; margin-bottom:4px; color:var(--text-primary);">Điện thoại</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">1900 - 1234</p>
                </div>
            </div>

            <div class="d-flex gap-3">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-envelope" style="color:var(--accent);"></i>
                </div>
                <div>
                    <h5 style="font-size:14px; font-weight:600; margin-bottom:4px; color:var(--text-primary);">Email</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">support@hd-rental.vn</p>
                </div>
            </div>
        </div>
    </div>
</div>
