@{
    ViewData["Title"] = "Hỗ trợ";
}

<!-- Hero Banner -->
<div style="position:relative; border-radius:var(--border-radius); overflow:hidden; height:180px; margin-bottom:32px; background:linear-gradient(135deg, #1a1a2e, #2a2a3e);">
    <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=800&q=80"
         style="width:100%; height:100%; object-fit:cover; opacity:0.3;" alt="Support"
         onerror="this.style.display='none'" />
    <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center;">
        <h1 style="font-size:28px; font-weight:700; font-style:italic;">Hỗ Trợ Khách Hàng 24/7</h1>
        <p style="font-size:14px; color:var(--text-secondary); margin:8px 0 16px;">Chúng tôi ở đây để giúp hành trình của bạn không bị gián đoạn.</p>
        <div class="input-group" style="max-width:480px;">
            <span class="input-group-text"><i class="fas fa-search"></i></span>
            <input type="text" class="form-control" placeholder="Bạn cần hỗ trợ điều gì?" style="font-size:13px;" />
            <button class="btn-hd" style="padding:8px 20px;">Tìm kiếm</button>
        </div>
    </div>
</div>

<!-- Categories -->
<h3 style="font-size:20px; font-weight:700; font-style:italic; margin-bottom:20px;">Danh mục phổ biến</h3>
<div class="row g-3 mb-5">
    <!-- Thuê xe & Đặt trước -->
    <div class="col-md-6">
        <a href="@Url.Action("DanhSach", "Xe")" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-motorcycle" style="color:#e8731a;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Thuê xe & Đặt trước</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Quy trình, điều kiện, và quản lý chuyến đi.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>

    <!-- Bảo hiểm & Pháp lý -->
    <div class="col-md-6">
        <a href="@Url.Action("BaoHiem", "Home")" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-shield-alt" style="color:#fbbf24;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Bảo hiểm & Pháp lý</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Chính sách bảo hiểm, trách nhiệm bồi thường.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>

    <!-- Thanh toán -->
    <div class="col-md-6">
        <a href="#" onclick="showPaymentFAQ(); return false;" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-credit-card" style="color:#4ade80;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Thanh toán</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Hóa đơn, phương thức thanh toán, hoàn tiền.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>

    <!-- Hỗ trợ kỹ thuật -->
    <div class="col-md-6">
        <a href="#" onclick="showRescueModal(); return false;" style="text-decoration:none; color:inherit; display:block;">
            <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); padding:20px; display:flex; gap:16px; align-items:flex-start; cursor:pointer; transition:0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border-color)'">
                <div style="width:40px; height:40px; background:rgba(232,115,26,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fas fa-wrench" style="color:#60a5fa;"></i>
                </div>
                <div>
                    <h5 style="font-size:15px; font-weight:600; margin-bottom:4px;">Hỗ trợ kỹ thuật</h5>
                    <p style="font-size:13px; color:var(--text-secondary); margin:0;">Xử lý sự cố trên đường, hướng dẫn vận hành.</p>
                </div>
                <div style="margin-left:auto; color:var(--accent);"><i class="fas fa-chevron-right"></i></div>
            </div>
        </a>
    </div>
</div>

<!-- FAQ -->
<h3 style="font-size:20px; font-weight:700; font-style:italic; margin-bottom:20px;">Câu hỏi thường gặp</h3>
<div class="mb-5 accordion" id="faqAccordion">
    @{
        var faqs = new[] {
            new { Id = "faq1", Q = "Tôi cần những giấy tờ gì để thuê xe?", A = "Bạn cần CCCD/CMND còn hiệu lực và Giấy phép lái xe hạng A2 trở lên. Đối với khách quốc tế, cần hộ chiếu và bằng lái quốc tế." },
            new { Id = "faq2", Q = "Chính sách hủy đặt xe như thế nào?", A = "Hủy trước 48 giờ: hoàn 100% tiền cọc. Hủy trước 24 giờ: hoàn 50%. Hủy trong vòng 24 giờ: không hoàn tiền cọc." },
            new { Id = "faq3", Q = "Tôi có thể gia hạn thuê xe không?", A = "Có, bạn có thể gia hạn thuê xe trực tiếp trên ứng dụng hoặc liên hệ hotline. Phí gia hạn tính theo giá thuê ngày hiện tại." }
        };
    }
    @foreach (var faq in faqs)
    {
        <div class="accordion-item" style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius); margin-bottom:12px; overflow:hidden;">
            <h2 class="accordion-header" id="heading-@faq.Id">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@faq.Id" aria-expanded="false" aria-controls="collapse-@faq.Id" style="background:transparent; color:var(--text-primary); box-shadow:none; font-size:14px; font-weight:600; padding:20px;">
                    @faq.Q
                </button>
            </h2>
            <div id="collapse-@faq.Id" class="accordion-collapse collapse" aria-labelledby="heading-@faq.Id" data-bs-parent="#faqAccordion">
                <div class="accordion-body" style="padding:0 20px 20px; font-size:13px; color:var(--text-secondary);">
                    @faq.A
                </div>
            </div>
        </div>
    }
</div>

<!-- Emergency Hotline -->
<div style="background:linear-gradient(135deg, #2a1508, #3a2010); border:1px solid rgba(232,115,26,0.3); border-radius:var(--border-radius); padding:24px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
    <div class="d-flex gap-3 align-items-center">
        <div style="width:48px; height:48px; background:var(--accent); border-radius:50%; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-phone-alt" style="font-size:20px;"></i>
        </div>
        <div>
            <h4 style="font-size:18px; font-weight:700; margin-bottom:2px;">Đường Dây Nóng Khẩn Cấp 24/7</h4>
            <p style="font-size:13px; color:var(--text-secondary); margin:0;">Hỗ trợ tai nạn, hỏng hóc nghiêm trọng trên đường.</p>
        </div>
    </div>
    <div style="display:flex; align-items:center; gap:12px;">
        <i class="fas fa-exclamation-triangle" style="font-size:28px; color:#fbbf24;"></i>
        <span style="font-size:24px; font-weight:700; color:var(--accent); letter-spacing:2px;">1900 - 1234</span>
    </div>
</div>
