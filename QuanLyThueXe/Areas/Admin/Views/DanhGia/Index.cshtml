@model IEnumerable<QuanLyThueXe.Models.DanhGia>

@{
    ViewData["Title"] = "Quản lý Đánh giá";

    int tongDanhGia  = ViewBag.TongDanhGia  ?? 0;
    double trungBinh = ViewBag.TrungBinhSao ?? 0.0;
    int dangHien     = ViewBag.DangHienThi  ?? 0;
    int dangAn       = ViewBag.DangAn       ?? 0;

    int trangHT      = ViewBag.TrangHienTai ?? 1;
    int tongTrang    = ViewBag.TongTrang    ?? 1;
    int tongKQ       = ViewBag.TongKetQua   ?? 0;

    int?   filterSao    = ViewBag.SoSao    as int?;
    string filterTT     = ViewBag.TrangThai ?? "";
    string filterKW     = ViewBag.Keyword   ?? "";

    var phanBo = (dynamic)ViewBag.PhanBoSao;
}

<div class="container-fluid py-4">

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold text-white mb-1">
                <i class="fas fa-star text-warning me-2"></i>Quản lý Đánh giá
            </h3>
            <p class="text-muted small mb-0">Xem và kiểm duyệt đánh giá của khách hàng</p>
        </div>
    </div>

    @* Stat cards *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(255,193,7,0.12);color:#ffc107;">
                    <i class="fas fa-star"></i>
                </div>
                <div>
                    <div class="stat-label">Tổng đánh giá</div>
                    <div class="stat-value">@tongDanhGia</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(255,122,0,0.12);color:#FF7A00;">
                    <i class="fas fa-star-half-alt"></i>
                </div>
                <div>
                    <div class="stat-label">Điểm trung bình</div>
                    <div class="stat-value">@trungBinh.ToString("0.0") <span style="font-size:1rem;color:#ffc107;">★</span></div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(25,135,84,0.12);color:#198754;">
                    <i class="fas fa-eye"></i>
                </div>
                <div>
                    <div class="stat-label">Đang hiển thị</div>
                    <div class="stat-value">@dangHien</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(100,100,100,0.12);color:#666;">
                    <i class="fas fa-eye-slash"></i>
                </div>
                <div>
                    <div class="stat-label">Đã ẩn</div>
                    <div class="stat-value">@dangAn</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        @* Phân bổ sao *@
        <div class="col-lg-4">
            <div class="panel">
                <div class="panel-title mb-4">
                    <i class="fas fa-chart-bar me-2"></i> Phân bổ số sao
                </div>
                @for (int s = 5; s >= 1; s--)
                {
                    var item = ((IEnumerable<dynamic>)phanBo).FirstOrDefault(x => x.Sao == s);
                    int soLuong = item != null ? (int)item.SoLuong : 0;
                    int pct = tongDanhGia > 0 ? (int)((double)soLuong / tongDanhGia * 100) : 0;
                    <div class="sao-row mb-2">
                        <a asp-action="Index"
                           asp-route-soSao="@s"
                           asp-route-trangThai="@filterTT"
                           asp-route-keyword="@filterKW"
                           class="sao-filter-link @(filterSao == s ? "active" : "")">
                            <span class="sao-label">@s ★</span>
                            <div class="sao-bar-track">
                                <div class="sao-bar-fill" style="width:@pct%;background:@(s >= 4 ? "#198754" : s == 3 ? "#ffc107" : "#dc3545");"></div>
                            </div>
                            <span class="sao-count">@soLuong</span>
                        </a>
                    </div>
                }
                @if (filterSao.HasValue)
                {
                    <div class="mt-3">
                        <a asp-action="Index" asp-route-trangThai="@filterTT" asp-route-keyword="@filterKW"
                           class="btn-reset-filter">
                            <i class="fas fa-times me-1"></i> Bỏ lọc sao
                        </a>
                    </div>
                }
            </div>
        </div>

        @* Filter + Table *@
        <div class="col-lg-8">
            @* Filter *@
            <div class="filter-box mb-3">
                <form asp-action="Index" method="get" class="row g-2 align-items-end">
                    <input type="hidden" name="soSao" value="@filterSao" />
                    <div class="col-md-4">
                        <label class="filter-label">Trạng thái hiển thị</label>
                        <select name="trangThai" class="dark-select w-100">
                            <option value="">Tất cả</option>
                            <option value="hien" selected="@(filterTT == "hien" ? "selected" : null)">Đang hiển thị</option>
                            <option value="an"   selected="@(filterTT == "an"   ? "selected" : null)">Đã ẩn</option>
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="filter-label">Tìm kiếm</label>
                        <div class="search-wrap">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" name="keyword" class="dark-input-sm ps-5 w-100"
                                   placeholder="Tên khách, tên xe, nội dung..." value="@filterKW" />
                        </div>
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn-filter flex-fill">
                            <i class="fas fa-search me-1"></i> Lọc
                        </button>
                        <a asp-action="Index" class="btn-reset-icon" title="Xóa bộ lọc">
                            <i class="fas fa-rotate-left"></i>
                        </a>
                    </div>
                </form>
            </div>

            @* Kết quả *@
            <div class="text-muted small mb-2">
                Tìm thấy <strong class="text-white">@tongKQ</strong> đánh giá
                @if (filterSao.HasValue) { <span> · Lọc: @filterSao ★</span> }
            </div>

            @* Danh sách đánh giá *@
            @if (Model != null && Model.Any())
            {
                @foreach (var dg in Model)
                {
                    <div class="review-card @(!dg.IsHienThi ? "review-hidden" : "")">
                        <div class="review-header">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar">
                                    @dg.KhachHang.HoTen.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <div class="reviewer-name">@dg.KhachHang.HoTen</div>
                                    <div class="reviewer-sub">
                                        <i class="fas fa-motorcycle me-1"></i>@dg.Xe.TenXe
                                        <span class="mx-2 text-muted">·</span>
                                        <i class="fas fa-file-contract me-1"></i>HD #@dg.MaHopDong
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="stars-display">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= dg.SoSao ? "star-on" : "star-off")"></i>
                                    }
                                </div>
                                @if (!dg.IsHienThi)
                                {
                                    <span class="badge-hidden"><i class="fas fa-eye-slash me-1"></i>Đã ẩn</span>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(dg.NhanXet))
                        {
                            <div class="review-content">
                                <i class="fas fa-quote-left text-muted me-2" style="font-size:0.75rem;"></i>
                                @dg.NhanXet
                            </div>
                        }
                        else
                        {
                            <div class="review-content text-muted fst-italic" style="font-size:0.82rem;">
                                Không có nhận xét
                            </div>
                        }

                        <div class="review-footer">
                            <span class="review-date">
                                <i class="fas fa-clock me-1"></i>
                                @dg.NgayDanhGia.ToString("HH:mm · dd/MM/yyyy")
                            </span>
                            <div class="review-footer">
                                <span class="review-date">
                                    <i class="fas fa-clock me-1"></i>
                                    @dg.NgayDanhGia.ToString("HH:mm · dd/MM/yyyy")
                                </span>
                                <form asp-action="Delete" asp-route-id="@dg.MaDanhGia" method="post"
                                      onsubmit="return confirm('Xác nhận xóa đánh giá này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action btn-delete" title="Xóa">
                                        <i class="fas fa-trash me-1"></i> Xóa
                                    </button>
                                </form>
                            </div>

                            @* Phản hồi admin *@
                            @if (!string.IsNullOrEmpty(dg.PhanHoiAdmin))
                            {
                                <div class="admin-reply">
                                    <div class="admin-reply-header">
                                        <i class="fas fa-reply me-1"></i> Phản hồi của Admin
                                        <span class="text-muted ms-2" style="font-size:0.72rem;">
                                            @dg.NgayPhanHoi?.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </div>
                                    <div class="admin-reply-text">@dg.PhanHoiAdmin</div>
                                    <form asp-action="PhanHoi" asp-route-id="@dg.MaDanhGia" method="post" class="mt-2">
                                        @Html.AntiForgeryToken()
                                        <div class="d-flex gap-2">
                                            <input type="text" name="phanHoiAdmin" class="dark-input-sm flex-fill"
                                                   value="@dg.PhanHoiAdmin" placeholder="Sửa phản hồi..." />
                                            <button type="submit" class="btn-reply">Cập nhật</button>
                                        </div>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <form asp-action="PhanHoi" asp-route-id="@dg.MaDanhGia" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <div class="d-flex gap-2">
                                        <input type="text" name="phanHoiAdmin" class="dark-input-sm flex-fill"
                                               placeholder="Nhập phản hồi cho khách hàng..." />
                                        <button type="submit" class="btn-reply">
                                            <i class="fas fa-paper-plane me-1"></i> Gửi
                                        </button>
                                    </div>
                                </form>
                            }
                        </div>
                    </div>
                }

                @* Pagination *@
                @if (tongTrang > 1)
                {
                    <div class="d-flex justify-content-center gap-2 mt-4">
                        @for (int p = 1; p <= tongTrang; p++)
                        {
                            <a asp-action="Index"
                               asp-route-trang="@p"
                               asp-route-soSao="@filterSao"
                               asp-route-trangThai="@filterTT"
                               asp-route-keyword="@filterKW"
                               class="page-btn @(p == trangHT ? "page-active" : "")">
                                @p
                            </a>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-star-half-alt"></i>
                    <div>Không có đánh giá nào</div>
                    <small>Thử thay đổi bộ lọc để tìm kiếm</small>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Stat cards */
    .stat-card {
        background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px;
        padding:16px 20px; display:flex; align-items:center; gap:16px;
    }
    .stat-icon { width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0; }
    .stat-label { font-size:0.72rem; color:#555; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; }
    .stat-value { font-size:1.5rem; font-weight:800; color:#fff; line-height:1.2; }

    /* Panel */
    .panel { background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px; padding:20px; height:100%; }
    .panel-title { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#555; display:flex; align-items:center; padding-bottom:12px; border-bottom:1px solid #2A2A2A; }

    /* Phân bổ sao */
    .sao-row { }
    .sao-filter-link {
        display:flex; align-items:center; gap:10px; text-decoration:none;
        padding:6px 8px; border-radius:8px; transition:background 0.15s;
    }
    .sao-filter-link:hover { background:rgba(255,255,255,0.04); }
    .sao-filter-link.active { background:rgba(255,122,0,0.08); }
    .sao-label { font-size:0.82rem; color:#888; width:32px; flex-shrink:0; font-weight:600; }
    .sao-bar-track { flex:1; height:6px; background:#2A2A2A; border-radius:6px; overflow:hidden; }
    .sao-bar-fill  { height:100%; border-radius:6px; transition:width 0.5s; }
    .sao-count { font-size:0.78rem; color:#555; width:28px; text-align:right; flex-shrink:0; }
    .btn-reset-filter { font-size:0.78rem; color:#555; text-decoration:none; padding:4px 10px; border:1px solid #2A2A2A; border-radius:6px; display:inline-flex; align-items:center; transition:all 0.2s; }
    .btn-reset-filter:hover { color:#FF7A00; border-color:#FF7A00; }

    /* Filter */
    .filter-box { background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px; padding:16px; }
    .filter-label { font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:#555; display:block; margin-bottom:5px; }
    .dark-select, .dark-input-sm {
        background:#161616 !important; border:1px solid #2A2A2A !important;
        color:#fff !important; border-radius:8px; padding:9px 12px; font-size:0.85rem;
    }
    .dark-select:focus, .dark-input-sm:focus { border-color:#FF7A00 !important; outline:none; box-shadow:0 0 0 3px rgba(255,122,0,0.1) !important; }
    .dark-input-sm::placeholder { color:#444 !important; }
    .search-wrap { position:relative; }
    .search-icon { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#555; pointer-events:none; }
    .btn-filter { background:#2A2A2A; color:#ccc; border:none; border-radius:8px; padding:9px 14px; font-size:0.85rem; cursor:pointer; transition:all 0.2s; }
    .btn-filter:hover { background:#333; color:#fff; }
    .btn-reset-icon { background:#1A1A1A; color:#666; border:1px solid #2A2A2A; border-radius:8px; padding:9px 13px; text-decoration:none; display:flex; align-items:center; transition:all 0.2s; }
    .btn-reset-icon:hover { color:#FF7A00; border-color:#FF7A00; }

    /* Review card */
    .review-card {
        background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px;
        padding:16px; margin-bottom:10px; transition:border-color 0.2s;
    }
    .review-card:hover { border-color:#333; }
    .review-hidden { opacity:0.55; border-style:dashed; }

    .review-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; flex-wrap:wrap; gap:8px; }
    .avatar {
        width:38px; height:38px; border-radius:10px; background:rgba(255,122,0,0.15);
        color:#FF7A00; font-weight:800; font-size:1rem; display:flex;
        align-items:center; justify-content:center; flex-shrink:0;
    }
    .reviewer-name { font-size:0.88rem; color:#ddd; font-weight:600; }
    .reviewer-sub  { font-size:0.75rem; color:#555; margin-top:2px; }

    .stars-display { display:flex; gap:3px; }
    .star-on  { color:#ffc107; font-size:0.85rem; }
    .star-off { color:#333;    font-size:0.85rem; }

    .badge-hidden { background:rgba(100,100,100,0.1); color:#666; border:1px solid #2A2A2A; border-radius:6px; padding:3px 10px; font-size:0.75rem; }

    .review-content { font-size:0.85rem; color:#aaa; line-height:1.6; padding:10px 12px; background:#161616; border-radius:8px; margin-bottom:12px; border-left:3px solid #2A2A2A; }

    .review-footer { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; }
    .review-date   { font-size:0.75rem; color:#444; }

    .btn-action { border:none; border-radius:7px; padding:6px 14px; font-size:0.78rem; cursor:pointer; font-weight:600; display:inline-flex; align-items:center; transition:all 0.2s; }
    .btn-hide   { background:rgba(100,100,100,0.1); color:#888; border:1px solid #2A2A2A; }
    .btn-hide:hover { background:rgba(100,100,100,0.2); color:#ccc; }
    .btn-show   { background:rgba(25,135,84,0.1); color:#198754; border:1px solid rgba(25,135,84,0.2); }
    .btn-show:hover { background:rgba(25,135,84,0.2); }
    .btn-delete { background:rgba(220,53,69,0.1); color:#dc3545; border:1px solid rgba(220,53,69,0.15); }
    .btn-delete:hover { background:rgba(220,53,69,0.2); }

    /* Pagination */
    .page-btn { width:34px; height:34px; display:flex; align-items:center; justify-content:center; border-radius:8px; background:#1E1E1E; border:1px solid #2A2A2A; color:#666; text-decoration:none; font-size:0.83rem; transition:all 0.15s; }
    .page-btn:hover { border-color:#FF7A00; color:#FF7A00; }
    .page-active { background:rgba(255,122,0,0.12); border-color:#FF7A00; color:#FF7A00; font-weight:700; }

    /* Empty */
    .empty-state { text-align:center; padding:48px 20px; display:flex; flex-direction:column; align-items:center; gap:8px; }
    .empty-state i   { font-size:2rem; color:#333; }
    .empty-state div { color:#555; font-size:0.88rem; }
    .empty-state small { color:#444; font-size:0.78rem; }
    .admin-reply {
        background: #161616;
        border-left: 3px solid #FF7A00;
        border-radius: 0 8px 8px 0;
        padding: 10px 14px;
        margin-top: 8px;
    }

    .admin-reply-header {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #FF7A00;
        margin-bottom: 6px;
    }

    .admin-reply-text {
        font-size: 0.83rem;
        color: #aaa;
        margin-bottom: 8px;
    }

    .btn-reply {
        background: #FF7A00;
        color: #111;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-size: 0.83rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s;
    }

        .btn-reply:hover {
            background: #e86d00;
        }
</style>
