<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />

    <style>
        /* 1. KHÓA CHẶT BODY: Khắc phục lỗi kéo đi tùm lum toàn trang */
        body {
        background-color: #121212;
        color: #fff;
        font-family: 'Inter', sans-serif;
        overflow: hidden !important; /* CẤM TUYỆT ĐỐI CUỘN NGOÀI */
        margin: 0;
        padding: 0;
        width: 100vw;
        height: 100vh;
        }

        .admin-wrapper {
        display: flex;
        width: 100%;
        height: 100%;
        }

        /* 2. SIDEBAR: Khắc phục lỗi thanh cuộn ngang */
        .sidebar {
        width: 250px;
        background: #1E1E1E;
        border-right: 1px solid #2A2A2A;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        overflow-y: auto;
        overflow-x: hidden; /* CẮT BỎ THANH SCROLL NGANG */
        }

        /* Làm đẹp thanh cuộn cho Sidebar */
        .sidebar::-webkit-scrollbar {
        width: 5px;
        }

        .sidebar::-webkit-scrollbar-thumb {
        background: #333;
        border-radius: 5px;
        }

        .sidebar .nav-link {
        color: #A0A0A0;
        padding: 0.8rem 1rem;
        border-radius: 8px;
        margin: 0.2rem 1rem;
        transition: 0.3s;
        text-decoration: none;
        }

        .sidebar .nav-link:hover, .sidebar .nav-link.active {
        background: rgba(255, 122, 0, 0.1);
        color: #FF7A00;
        }

        .sidebar .nav-link i {
        margin-right: 0.5rem;
        width: 20px;
        text-align: center;
        }

        /* 3. MAIN CONTENT: Chặn tràn lề Bootstrap */
        .main-content {
        flex-grow: 1;
        background-color: #121212;
        height: 100vh;
        overflow-y: auto; /* Chỉ cho phép cuộn dọc nội dung */
        overflow-x: hidden; /* CHẶN TRỤC NGANG ĐỂ KHÔNG BỊ TRƯỢT TRANG */
        padding: 1.5rem;
        }

        .main-content::-webkit-scrollbar {
        width: 8px;
        }

        .main-content::-webkit-scrollbar-thumb {
        background: #444;
        border-radius: 4px;
        }

        .btn-logout {
        color: #dc3545 !important;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        }

        .btn-logout:hover {
        background: rgba(220, 53, 69, 0.1) !important;
        color: #dc3545 !important;
        }
    </style>
</head>
<body>
    <div class="admin-wrapper">
        <nav class="sidebar pt-3">
            <div class="text-center text-white mb-4 mt-2">
                <h4 class="fw-bold"><i class="fas fa-motorcycle text-warning"></i> Admin Panel</h4>
                <small class="text-muted">@User.Identity?.Name</small>
            </div>

            @{
                // Lấy tên Controller hiện tại để biết đang ở trang nào
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            }

            <ul class="nav flex-column mb-auto">
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Dashboard" ? "active" : "")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Xe" ? "active" : "")" asp-area="Admin" asp-controller="Xe" asp-action="Index">
                        <i class="fas fa-motorcycle"></i> Quản lý xe
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "KhachHang" ? "active" : "")" asp-area="Admin" asp-controller="KhachHang" asp-action="Index">
                        <i class="fas fa-users"></i> Khách hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "HopDong" ? "active" : "")" asp-area="Admin" asp-controller="HopDong" asp-action="Index">
                        <i class="fas fa-file-contract"></i> Hợp đồng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "BaoDuong" ? "active" : "")" asp-area="Admin" asp-controller="BaoDuong" asp-action="Index">
                        <i class="fas fa-tools"></i> Bảo dưỡng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "KhuyenMai" ? "active" : "")" asp-area="Admin" asp-controller="KhuyenMai" asp-action="Index">
                        <i class="fas fa-gift"></i> Khuyến mãi
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "DanhGia" ? "active" : "")" asp-area="Admin" asp-controller="DanhGia" asp-action="Index">
                        <i class="fas fa-star"></i> Đánh giá
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "BaoCao" ? "active" : "")" asp-area="Admin" asp-controller="BaoCao" asp-action="Index">
                        <i class="fas fa-chart-bar"></i> Báo cáo
                    </a>
                </li>
                <hr class="bg-secondary mx-3" />
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-home"></i> Về trang chủ
                    </a>
                </li>
                <li class="nav-item">
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="nav-link btn-logout">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </button>
                    </form>
                </li>
            </ul>
        </nav>

        <main class="main-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()

        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>