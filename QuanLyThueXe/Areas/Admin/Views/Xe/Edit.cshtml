@model QuanLyThueXe.Models.Xe

@{
    ViewData["Title"] = "Chỉnh sửa xe - " + Model.TenXe;
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary text-white me-3 px-3">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
        </a>
        <h3 class="fw-bold text-white mb-0">
            Cập nhật thông tin: <span class="text-orange">@Model.TenXe</span>
        </h3>
    </div>

    <div class="dashboard-card max-width-800 mx-auto p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="MaXe" />
            <input type="hidden" asp-for="NgayTao" />

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="TenXe" class="form-label small text-muted fw-bold">Tên xe</label>
                    <input asp-for="TenXe" class="form-control bg-dark border-secondary text-white" placeholder="Ví dụ: Harley-Davidson Sportster S" />
                    <span asp-validation-for="TenXe" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="BienSo" class="form-label small text-muted fw-bold">Biển số xe</label>
                    <input asp-for="BienSo" class="form-control bg-dark border-secondary text-white" placeholder="Ví dụ: 51D1-11111" />
                    <span asp-validation-for="BienSo" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MaHangXe" class="form-label small text-muted fw-bold">Hãng sản xuất</label>
                    <select asp-for="MaHangXe" class="form-select bg-dark border-secondary text-white" asp-items="ViewBag.MaHangXe"></select>
                    <span asp-validation-for="MaHangXe" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MaPhongCach" class="form-label small text-muted fw-bold">Phong cách (Dáng xe)</label>
                    <select asp-for="MaPhongCach" class="form-select bg-dark border-secondary text-white" asp-items="ViewBag.MaPhongCach"></select>
                    <span asp-validation-for="MaPhongCach" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="GiaThueNgay" class="form-label small text-muted fw-bold">Giá thuê (VNĐ / Ngày)</label>
                    <input asp-for="GiaThueNgay" type="number" class="form-control bg-dark border-secondary text-white" />
                    <span asp-validation-for="GiaThueNgay" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="NamSanXuat" class="form-label small text-muted fw-bold">Năm sản xuất</label>
                    <input asp-for="NamSanXuat" type="number" class="form-control bg-dark border-secondary text-white" />
                    <span asp-validation-for="NamSanXuat" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DungTich" class="form-label small text-muted fw-bold">Dung tích (cc)</label>
                    <input asp-for="DungTich" type="number" class="form-control bg-dark border-secondary text-white" />
                    <span asp-validation-for="DungTich" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="TrangThai" class="form-label small text-muted fw-bold">Trạng thái xe trên hệ thống</label>
                    <select asp-for="TrangThai" class="form-select bg-dark border-secondary text-white">
                        <option value="ConTrong">Còn trống (Sẵn sàng cho thuê)</option>
                        <option value="DangThue">Đang cho thuê</option>
                        <option value="BaoDuong">Đang bảo dưỡng</option>
                        <option value="NgungHoatDong">Ngừng hoạt động / Thanh lý (Ẩn xe)</option>
                    </select>
                    <span asp-validation-for="TrangThai" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label small text-muted fw-bold">Bổ sung hình ảnh mới (nếu có)</label>
                    <input type="file" name="hinhAnhs" multiple class="form-control bg-dark border-secondary text-white" accept="image/*" />
                </div>

                <div class="col-12">
                    <label asp-for="MoTa" class="form-label small text-muted fw-bold">Mô tả chi tiết về xe</label>
                    <textarea asp-for="MoTa" class="form-control bg-dark border-secondary text-white" rows="4" placeholder="Nhập đặc điểm nổi bật, tình trạng xe..."></textarea>
                    <span asp-validation-for="MoTa" class="text-danger small"></span>
                </div>

                <div class="col-12 text-end mt-4 border-top border-secondary pt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary text-white me-2 px-4">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning fw-bold px-5">Lưu thay đổi</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}