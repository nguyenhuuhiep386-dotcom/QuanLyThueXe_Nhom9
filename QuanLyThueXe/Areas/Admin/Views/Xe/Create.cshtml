@model QuanLyThueXe.Models.Xe

@{
    ViewData["Title"] = "Thêm xe mới";

    // Tự động sinh danh sách Năm sản xuất từ 1990 đến năm hiện tại
    int currentYear = DateTime.Now.Year;
    var yearList = new SelectList(Enumerable.Range(1990, currentYear - 1990 + 1).OrderByDescending(y => y));
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h3 class="fw-bold text-white mb-1">Thêm xe mới</h3>
        <p class="text-muted small">Nhập thông tin chi tiết để thêm xe vào hệ thống</p>
    </div>

    <div class="dashboard-card max-width-1000 mx-auto p-4 rounded-4" style="background-color: #1E1E1E;">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label class="form-label small text-muted fw-bold">Hình Ảnh Xe</label>
                <div class="upload-zone position-relative d-flex flex-column align-items-center justify-content-center p-5 rounded-3"
                     style="border: 2px dashed #444; background-color: #121212; cursor: pointer; transition: 0.3s;"
                     onclick="document.getElementById('fileInput').click()">

                    <div class="icon-box mb-3 d-flex align-items-center justify-content-center rounded-3"
                         style="width: 60px; height: 60px; background-color: #2A2A2A;">
                        <i class="fa-regular fa-image fs-3 text-muted"></i>
                    </div>
                    <p class="text-white mb-1">Kéo thả hình ảnh vào đây hoặc <span class="text-orange">Chọn tệp</span></p>
                    <small class="text-muted">Định dạng hỗ trợ: JPG, PNG, WEBP (Tối đa 5MB)</small>

                    <input type="file" id="fileInput" name="hinhAnhs" multiple class="d-none" accept="image/*" onchange="updateFileName(this)" />
                </div>
                <div id="fileNames" class="text-orange small mt-2 fw-bold text-center"></div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="TenXe" class="form-label small text-muted fw-bold">Tên xe <span class="text-danger">*</span></label>
                    <input asp-for="TenXe" class="form-control bg-dark border-secondary text-white p-3" placeholder="Vd: Harley-Davidson Iron 883" required />
                    <span asp-validation-for="TenXe" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="GiaThueNgay" class="form-label small text-muted fw-bold">Giá thuê/ngày (VNĐ) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <input asp-for="GiaThueNgay" type="number" min="0" step="50000" class="form-control bg-dark border-secondary text-white p-3" placeholder="0" required />
                        <span class="input-group-text bg-dark border-secondary text-muted px-4">đ</span>
                    </div>
                    <span asp-validation-for="GiaThueNgay" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="BienSo" class="form-label small text-muted fw-bold">Biển số <span class="text-danger">*</span></label>
                    <input asp-for="BienSo" class="form-control bg-dark border-secondary text-white p-3" placeholder="Vd: 29A1-123.45" required />
                    <span asp-validation-for="BienSo" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="TrangThai" class="form-label small text-muted fw-bold">Trạng thái hiện tại</label>
                    <select asp-for="TrangThai" class="form-select bg-dark border-secondary text-white p-3">
                        <option value="ConTrong">Còn trống (Sẵn sàng)</option>
                        <option value="BaoDuong">Đang bảo dưỡng</option>
                        <option value="NgungHoatDong">Ngừng hoạt động</option>
                    </select>
                    <span asp-validation-for="TrangThai" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MaHangXe" class="form-label small text-muted fw-bold">Hãng xe</label>
                    <select asp-for="MaHangXe" class="form-select bg-dark border-secondary text-white p-3" asp-items="ViewBag.MaHangXe">
                        <option value="">-- Chọn hãng xe --</option>
                    </select>
                    <span asp-validation-for="MaHangXe" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MaPhongCach" class="form-label small text-muted fw-bold">Phong cách</label>
                    <select asp-for="MaPhongCach" class="form-select bg-dark border-secondary text-white p-3" asp-items="ViewBag.MaPhongCach">
                        <option value="">-- Chọn phong cách --</option>
                    </select>
                    <span asp-validation-for="MaPhongCach" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="NamSanXuat" class="form-label small text-muted fw-bold">Năm sản xuất</label>
                    <select asp-for="NamSanXuat" class="form-select bg-dark border-secondary text-white p-3" asp-items="yearList">
                        <option value="">-- Chọn năm sản xuất --</option>
                    </select>
                    <span asp-validation-for="NamSanXuat" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="DungTich" class="form-label small text-muted fw-bold">Dung tích (cc)</label>
                    <input asp-for="DungTich" type="number" min="0" step="10" class="form-control bg-dark border-secondary text-white p-3" placeholder="Vd: 150" />
                    <span asp-validation-for="DungTich" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="MoTa" class="form-label small text-muted fw-bold">Mô tả chi tiết</label>
                    <textarea asp-for="MoTa" class="form-control bg-dark border-secondary text-white p-3" rows="4" placeholder="Nhập thông tin mô tả chi tiết về xe, tình trạng bảo dưỡng, các phụ kiện đi kèm..."></textarea>
                    <span asp-validation-for="MoTa" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-5 pt-3 border-top border-secondary">
                <a asp-action="Index" class="btn btn-outline-secondary text-white px-5 py-2 fw-bold" style="background-color: #2A2A2A; border: none;">Hủy</a>
                <button type="submit" class="btn btn-warning px-5 py-2 fw-bold text-dark" style="background-color: #FF7A00; border: none;">Lưu dữ liệu</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Hiệu ứng hover cho khu vực kéo thả ảnh
        const uploadZone = document.querySelector('.upload-zone');
        uploadZone.addEventListener('mouseover', () => uploadZone.style.borderColor = '#FF7A00');
        uploadZone.addEventListener('mouseout', () => uploadZone.style.borderColor = '#444');

        // Hiển thị tên/số lượng file đã chọn
        function updateFileName(input) {
            const display = document.getElementById('fileNames');
            if (input.files && input.files.length > 0) {
                if (input.files.length === 1) {
                    display.innerText = "Đã chọn: " + input.files[0].name;
                } else {
                    display.innerText = "Đã chọn " + input.files.length + " hình ảnh";
                }
            } else {
                display.innerText = "";
            }
        }
    </script>
}