@model IEnumerable<QuanLyThueXe.Models.KhuyenMai>

@{
    ViewData["Title"] = "Quản lý Khuyến mãi";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-white mb-1">Quản lý Khuyến mãi</h3>
            <p class="text-muted small mb-0">Tạo và theo dõi các chương trình ưu đãi</p>
        </div>
        <a asp-action="Create" class="btn-add">
            <i class="fa-solid fa-plus me-2"></i> Tạo khuyến mãi mới
        </a>
    </div>

    @* Stat cards *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(255,122,0,0.12); color:#FF7A00;">
                    <i class="fa-solid fa-gift"></i>
                </div>
                <div>
                    <div class="stat-label">Tổng chương trình</div>
                    <div class="stat-value">@(Model?.Count() ?? 0)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(25,135,84,0.12); color:#198754;">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <div class="stat-label">Đang hoạt động</div>
                    <div class="stat-value">
                        @(Model?.Count(k => k.IsActive && k.DenNgay >= DateTime.Now) ?? 0)
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(13,110,253,0.12); color:#4d8fff;">
                    <i class="fa-solid fa-ticket"></i>
                </div>
                <div>
                    <div class="stat-label">Lượt đã dùng</div>
                    <div class="stat-value">@(Model?.Sum(k => k.DaSuDung) ?? 0)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(220,53,69,0.12); color:#dc3545;">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                </div>
                <div>
                    <div class="stat-label">Hết hạn</div>
                    <div class="stat-value">
                        @(Model?.Count(k => k.DenNgay < DateTime.Now) ?? 0)
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Filter *@
    <div class="filter-box mb-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="filter-label">Trạng thái</label>
                <select name="trangThai" class="dark-select">
                    <option value="">Tất cả</option>
                    <option value="active"   selected="@(ViewBag.TrangThai == "active"   ? "selected" : null)">Đang hoạt động</option>
                    <option value="expired"  selected="@(ViewBag.TrangThai == "expired"  ? "selected" : null)">Hết hạn</option>
                    <option value="inactive" selected="@(ViewBag.TrangThai == "inactive" ? "selected" : null)">Đã tắt</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="filter-label">Loại giảm giá</label>
                <select name="loaiGiam" class="dark-select">
                    <option value="">Tất cả</option>
                    <option value="PhanTram"      selected="@(ViewBag.LoaiGiam == "PhanTram"      ? "selected" : null)">Phần trăm (%)</option>
                    <option value="SoTienCoDinh"  selected="@(ViewBag.LoaiGiam == "SoTienCoDinh" ? "selected" : null)">Số tiền cố định</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="filter-label">Tìm mã code</label>
                <div class="search-wrap">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input type="text" name="keyword" class="dark-input-sm ps-5"
                           placeholder="Nhập mã code..." value="@ViewBag.Keyword" />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-filter flex-fill">
                    <i class="fa-solid fa-magnifying-glass me-1"></i> Lọc
                </button>
                <a asp-action="Index" class="btn-reset">
                    <i class="fa-solid fa-rotate-left"></i>
                </a>
            </div>
        </form>
    </div>

    @* Table *@
    <div class="table-wrap">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead>
                <tr class="table-head">
                    <th class="ps-4">Chương trình</th>
                    <th>Mã Code</th>
                    <th>Loại giảm</th>
                    <th class="text-center">Lượt dùng</th>
                    <th>Thời hạn</th>
                    <th>Điều kiện tối thiểu</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var isExpired  = item.DenNgay < DateTime.Now;
                        var isFull     = item.DaSuDung >= item.SoLanSuDung;
                        var isActive   = item.IsActive && !isExpired && !isFull;

                        <tr class="table-row">
                            <td class="ps-4">
                                <div class="text-white fw-medium" style="font-size:0.88rem;">@item.TenChuongTrinh</div>
                                <div class="text-muted" style="font-size:0.75rem;">
                                    Tạo: @item.NgayTao.ToString("dd/MM/yyyy")
                                </div>
                            </td>

                            <td>
                                <span class="code-badge">@item.MaCode</span>
                            </td>

                            <td>
                                @if (item.LoaiGiamGia == "PhanTram")
                                {
                                    <div class="discount-cell discount-percent">
                                        <i class="fa-solid fa-percent me-1" style="font-size:0.75rem;"></i>
                                        Giảm @item.GiaTriGiam.ToString("0")%
                                    </div>
                                    @if (item.GiaTriGiamToiDa.HasValue)
                                    {
                                        <div class="text-muted" style="font-size:0.72rem;">
                                            Tối đa @item.GiaTriGiamToiDa.Value.ToString("N0")đ
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="discount-cell discount-fixed">
                                        <i class="fa-solid fa-tag me-1" style="font-size:0.75rem;"></i>
                                        Giảm @item.GiaTriGiam.ToString("N0")đ
                                    </div>
                                }
                            </td>

                            <td class="text-center">
                                <div class="usage-wrap">
                                    <div class="usage-text">
                                        <span class="text-white fw-semibold">@item.DaSuDung</span>
                                        <span class="text-muted"> / @item.SoLanSuDung</span>
                                    </div>
                                    <div class="usage-bar">
                                        <div class="usage-fill @(isFull ? "fill-full" : "fill-active")"
                                             style="width:@(Math.Min(100, (int)((double)item.DaSuDung / item.SoLanSuDung * 100)))%">
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="text-white" style="font-size:0.82rem;">
                                    @item.TuNgay.ToString("dd/MM/yyyy")
                                </div>
                                <div class="text-muted" style="font-size:0.75rem;">
                                    → @item.DenNgay.ToString("dd/MM/yyyy")
                                </div>
                            </td>

                            <td class="text-muted" style="font-size:0.83rem;">
                                @(item.DieuKienToiThieu.HasValue
                                    ? item.DieuKienToiThieu.Value.ToString("N0") + "đ"
                                    : "Không")
                            </td>

                            <td class="text-center">
                                @if (!item.IsActive)
                                {
                                    <span class="status-badge status-off">
                                        <span class="sdot"></span> Đã tắt
                                    </span>
                                }
                                else if (isExpired)
                                {
                                    <span class="status-badge status-expired">
                                        <span class="sdot"></span> Hết hạn
                                    </span>
                                }
                                else if (isFull)
                                {
                                    <span class="status-badge status-full">
                                        <span class="sdot"></span> Hết lượt
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-active">
                                        <span class="sdot"></span> Đang chạy
                                    </span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-3">
                                    <a asp-action="Details" asp-route-id="@item.MaKhuyenMai"
                                       class="action-btn" title="Chi tiết">
                                        <i class="fa-regular fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.MaKhuyenMai"
                                       class="action-btn" title="Chỉnh sửa">
                                        <i class="fa-regular fa-pen-to-square"></i>
                                    </a>
                                    <form asp-action="ToggleActive" asp-route-id="@item.MaKhuyenMai"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="action-btn border-0 bg-transparent p-0 @(item.IsActive ? "text-warning" : "text-success")"
                                                title="@(item.IsActive ? "Tắt" : "Bật")">
                                            <i class="fa-solid fa-power-off"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <i class="fa-solid fa-gift text-muted mb-3" style="font-size:2rem; display:block;"></i>
                            <span class="text-muted">Chưa có chương trình khuyến mãi nào.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="table-footer">
            <span class="text-muted small">
                Tổng: <strong class="text-white">@(Model?.Count() ?? 0)</strong> chương trình
            </span>
        </div>
    </div>
</div>

<style>
    .stat-card {
        background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px;
        padding:16px 20px; display:flex; align-items:center; gap:16px;
    }
    .stat-icon {
        width:44px; height:44px; border-radius:10px;
        display:flex; align-items:center; justify-content:center;
        font-size:1.1rem; flex-shrink:0;
    }
    .stat-label { font-size:0.72rem; color:#666; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; }
    .stat-value { font-size:1.3rem; font-weight:700; color:#fff; line-height:1.2; }

    .filter-box { background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px; padding:20px; }
    .filter-label { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:#555; display:block; margin-bottom:6px; }

    .dark-select, .dark-input-sm {
        width:100%; background:#161616 !important; border:1px solid #2A2A2A !important;
        color:#fff !important; border-radius:8px; padding:9px 12px; font-size:0.85rem;
    }
    .dark-select:focus, .dark-input-sm:focus {
        border-color:#FF7A00 !important; outline:none;
        box-shadow:0 0 0 3px rgba(255,122,0,0.1) !important;
    }
    .search-wrap { position:relative; }
    .search-icon { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#555; pointer-events:none; }

    .btn-add {
        background:#FF7A00; color:#111; border:none; border-radius:8px;
        padding:10px 20px; font-weight:700; font-size:0.85rem;
        text-decoration:none; transition:all 0.2s; display:inline-flex; align-items:center;
    }
    .btn-add:hover { background:#e86d00; color:#000; }
    .btn-filter { background:#2A2A2A; color:#ccc; border:none; border-radius:8px; padding:9px 16px; font-size:0.85rem; cursor:pointer; transition:all 0.2s; }
    .btn-filter:hover { background:#333; color:#fff; }
    .btn-reset { background:#1A1A1A; color:#666; border:1px solid #2A2A2A; border-radius:8px; padding:9px 14px; text-decoration:none; display:flex; align-items:center; transition:all 0.2s; }
    .btn-reset:hover { color:#FF7A00; border-color:#FF7A00; }

    .table-wrap { background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px; overflow:hidden; }
    .table-head th { background:#1A1A1A; color:#555; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; padding:14px 12px; border:none; }
    .table-row td { border-color:#222 !important; padding:12px; }
    .table-row:hover td { background:rgba(255,122,0,0.03) !important; }

    .code-badge {
        background:#161616; border:1px solid #333; border-radius:6px;
        padding:4px 10px; font-size:0.8rem; color:#FF7A00;
        font-family:monospace; font-weight:600; letter-spacing:0.05em;
    }

    .discount-cell { font-size:0.83rem; font-weight:600; }
    .discount-percent { color:#ffc107; }
    .discount-fixed   { color:#4d8fff; }

    .usage-wrap { min-width:80px; }
    .usage-text { font-size:0.8rem; margin-bottom:4px; }
    .usage-bar { height:4px; background:#2A2A2A; border-radius:4px; overflow:hidden; }
    .usage-fill { height:100%; border-radius:4px; transition:width 0.6s ease; }
    .fill-active { background:linear-gradient(90deg, #FF7A00, #ffc107); }
    .fill-full   { background:#dc3545; }

    .status-badge { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; border-radius:20px; font-size:0.78rem; font-weight:500; }
    .sdot { width:6px; height:6px; border-radius:50%; display:inline-block; }
    .status-active  { background:rgba(25,135,84,0.1);  color:#198754; border:1px solid rgba(25,135,84,0.2); }
    .status-active  .sdot { background:#198754; box-shadow:0 0 4px #198754; }
    .status-expired { background:rgba(220,53,69,0.1);  color:#dc3545; border:1px solid rgba(220,53,69,0.2); }
    .status-expired .sdot { background:#dc3545; box-shadow:0 0 4px #dc3545; }
    .status-full    { background:rgba(255,193,7,0.1);  color:#ffc107; border:1px solid rgba(255,193,7,0.2); }
    .status-full    .sdot { background:#ffc107; box-shadow:0 0 4px #ffc107; }
    .status-off     { background:rgba(100,100,100,0.1); color:#666;   border:1px solid rgba(100,100,100,0.2); }
    .status-off     .sdot { background:#555; }

    .action-btn { color:#555; text-decoration:none; font-size:1rem; transition:color 0.15s; background:none; border:none; padding:0; cursor:pointer; }
    .action-btn:hover { color:#fff; }
    .table-footer { padding:12px 16px; border-top:1px solid #222; background:#1A1A1A; }
</style>
