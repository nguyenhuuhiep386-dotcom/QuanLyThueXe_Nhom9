@model QuanLyThueXe.Models.BaoDuong

@{
    ViewData["Title"] = "Chi tiết Bảo dưỡng";
    var soNgay = Model.NgayRa.HasValue
        ? (Model.NgayRa.Value - Model.NgayVao).Days
        : (DateTime.Now - Model.NgayVao).Days;
    if (soNgay < 0) soNgay = 0;
}

<div class="container-fluid py-4 px-4" style="max-width:1000px;">

    @* Breadcrumb *@
    <nav class="mb-2" style="font-size:0.82rem;">
        <a asp-action="Index" class="text-muted text-decoration-none hover-white">Bảo dưỡng</a>
        <span class="text-muted mx-2">›</span>
        <span class="text-white">BD-@Model.MaBaoDuong.ToString("D3")</span>
    </nav>

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn-icon-back">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h4 class="fw-bold text-white mb-0">
                    Chi tiết Bảo dưỡng
                    <span class="text-muted fw-normal" style="font-size:0.9rem;"> #BD-@Model.MaBaoDuong.ToString("D3")</span>
                </h4>
            </div>
            @if (Model.TrangThai == "DangSua")
            {
                <span class="status-badge status-pending">
                    <span class="sdot"></span> Đang sửa
                </span>
            }
            else
            {
                <span class="status-badge status-done">
                    <span class="sdot"></span> Hoàn thành
                </span>
            }
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.MaBaoDuong"
               class="btn-outline-action">
                <i class="fa-regular fa-pen-to-square me-2"></i> Chỉnh sửa
            </a>
            @if (Model.TrangThai == "DangSua")
            {
                <form asp-action="HoanThanh" asp-route-id="@Model.MaBaoDuong" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-done">
                        <i class="fa-regular fa-circle-check me-2"></i> Đánh dấu Hoàn thành
                    </button>
                </form>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert mb-3" style="background:rgba(25,135,84,0.1);border:1px solid rgba(25,135,84,0.3);color:#198754;border-radius:10px;">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["SuccessMessage"]
        </div>
    }

    <div class="row g-4">

        @* CỘT TRÁI *@
        <div class="col-md-5">

            @* Thông tin xe *@
            <div class="panel-box mb-4">
                <div class="panel-title mb-3">
                    <i class="fa-solid fa-motorcycle me-2"></i> Thông tin xe
                </div>
                <div class="d-flex gap-3 align-items-start mb-3">
                    @{
                        var anhXe = Model.Xe?.HinhAnhs?.FirstOrDefault(a => a.IsAnhChinh)?.DuongDanAnh
                                 ?? Model.Xe?.HinhAnhs?.FirstOrDefault()?.DuongDanAnh;
                    }
                    @if (!string.IsNullOrEmpty(anhXe))
                    {
                        <img src="@anhXe" alt="Ảnh xe"
                             style="width:80px; height:60px; object-fit:cover; border-radius:8px; border:1px solid #2A2A2A;" />
                    }
                    else
                    {
                        <div style="width:80px; height:60px; background:#2A2A2A; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <i class="fa-solid fa-motorcycle text-muted fs-4"></i>
                        </div>
                    }
                    <div>
                        <div class="text-white fw-semibold">@(Model.Xe?.TenXe ?? "—")</div>
                        <div class="text-muted small">@(Model.Xe?.BienSo ?? "—")</div>
                        <div class="text-muted small mt-1">
                            <i class="fa-solid fa-tag me-1"></i>
                            @(Model.Xe?.HangXe?.TenHang ?? "—")
                        </div>
                    </div>
                </div>
            </div>

            @* Timeline *@
            <div class="panel-box mb-4">
                <div class="panel-title mb-3">
                    <i class="fa-regular fa-calendar me-2"></i> Thời gian
                </div>
                <div class="timeline-item mb-3">
                    <div class="tl-dot dot-orange"></div>
                    <div>
                        <div class="info-label">Ngày đưa vào</div>
                        <div class="info-value">@Model.NgayVao.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
                <div class="timeline-item mb-3">
                    <div class="tl-dot @(Model.NgayRa.HasValue ? "dot-green" : "dot-empty")"></div>
                    <div>
                        <div class="info-label">Ngày ra @(Model.NgayRa.HasValue ? "" : "(dự kiến)")</div>
                        <div class="info-value">
                            @(Model.NgayRa.HasValue ? Model.NgayRa.Value.ToString("dd/MM/yyyy") : "Chưa xác định")
                        </div>
                    </div>
                </div>
                <div class="duration-bar mt-3 pt-3" style="border-top:1px solid #2A2A2A;">
                    <span class="info-label">Thời gian bảo dưỡng</span>
                    <span class="text-white fw-bold ms-3">@soNgay ngày @(Model.NgayRa.HasValue ? "" : "(đang tính)")</span>
                </div>
            </div>

            @* Chi phí *@
            <div class="panel-box">
                <div class="panel-title mb-3">
                    <i class="fa-solid fa-sack-dollar me-2"></i> Chi phí
                </div>
                @if (Model.ChiPhi.HasValue)
                {
                    <div class="cost-display">
                        <div class="cost-label">Tổng chi phí</div>
                        <div class="cost-amount">@Model.ChiPhi.Value.ToString("N0")<span>đ</span></div>
                    </div>
                }
                else
                {
                    <div class="text-muted small text-center py-2">Chưa có thông tin chi phí</div>
                }
            </div>

        </div>

        @* CỘT PHẢI *@
        <div class="col-md-7">
            <div class="panel-box h-100">
                <div class="panel-title mb-4">
                    <i class="fa-solid fa-clipboard me-2"></i> Chi tiết công việc
                </div>

                <div class="mb-3">
                    <div class="info-label">Loại bảo dưỡng</div>
                    <div class="highlight-field">
                        <i class="fa-solid fa-screwdriver-wrench me-2" style="color:#FF7A00;"></i>
                        @Model.LoaiBaoDuong
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="info-label">Đơn vị thực hiện</div>
                        <div class="info-value">@(Model.DonViThucHien ?? "—")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-label">Người phụ trách</div>
                        <div class="info-value">@(Model.NguoiPhuTrach?.HoTen ?? "—")</div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="info-label mb-2">Ghi chú</div>
                    <div class="note-box">
                        @if (!string.IsNullOrEmpty(Model.GhiChu))
                        {
                            @Model.GhiChu
                        }
                        else
                        {
                            <span class="text-muted">Không có ghi chú.</span>
                        }
                    </div>
                </div>

                @* Progress indicator *@
                <div class="progress-section mt-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="info-label">Tiến độ</span>
                        <span class="text-white small fw-bold">
                            @(Model.TrangThai == "HoanThanh" ? "100%" : "Đang xử lý...")
                        </span>
                    </div>
                    <div class="progress-track">
                        <div class="progress-fill @(Model.TrangThai == "HoanThanh" ? "fill-done" : "fill-ongoing")">
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span class="step-label step-active">
                            <i class="fa-solid fa-circle-dot me-1"></i> Tiếp nhận
                        </span>
                        <span class="step-label @(Model.TrangThai == "HoanThanh" ? "step-active" : "step-inactive")">
                            <i class="fa-@(Model.TrangThai == "HoanThanh" ? "solid" : "regular") fa-circle me-1"></i> Đang sửa
                        </span>
                        <span class="step-label @(Model.TrangThai == "HoanThanh" ? "step-done" : "step-inactive")">
                            <i class="fa-@(Model.TrangThai == "HoanThanh" ? "solid" : "regular") fa-circle-check me-1"></i> Hoàn thành
                        </span>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<style>
    .hover-white:hover { color:#fff !important; }

    .btn-icon-back {
        width:36px; height:36px; background:#2A2A2A; border:none; border-radius:8px;
        color:#aaa; display:flex; align-items:center; justify-content:center;
        text-decoration:none; flex-shrink:0; transition:all 0.2s;
    }
    .btn-icon-back:hover { background:#333; color:#fff; }

    /* Status */
    .status-badge {
        display:inline-flex; align-items:center; gap:6px;
        padding:5px 12px; border-radius:20px; font-size:0.8rem; font-weight:500;
    }
    .sdot { width:6px; height:6px; border-radius:50%; display:inline-block; }
    .status-pending { background:rgba(255,193,7,0.1); color:#ffc107; border:1px solid rgba(255,193,7,0.25); }
    .status-pending .sdot { background:#ffc107; box-shadow:0 0 4px #ffc107; }
    .status-done { background:rgba(25,135,84,0.1); color:#198754; border:1px solid rgba(25,135,84,0.25); }
    .status-done .sdot { background:#198754; box-shadow:0 0 4px #198754; }

    /* Buttons */
    .btn-outline-action {
        background:transparent; color:#888; border:1px solid #2A2A2A;
        border-radius:8px; padding:8px 16px; font-size:0.83rem;
        text-decoration:none; transition:all 0.2s; display:inline-flex; align-items:center;
    }
    .btn-outline-action:hover { border-color:#555; color:#fff; }

    .btn-done {
        background:rgba(25,135,84,0.15); color:#198754;
        border:1px solid rgba(25,135,84,0.3); border-radius:8px;
        padding:8px 16px; font-size:0.83rem; cursor:pointer;
        transition:all 0.2s; display:inline-flex; align-items:center;
    }
    .btn-done:hover { background:rgba(25,135,84,0.25); }

    /* Panels */
    .panel-box {
        background:#1E1E1E; border:1px solid #2A2A2A;
        border-radius:12px; padding:20px;
    }
    .panel-title {
        font-size:0.75rem; font-weight:700; text-transform:uppercase;
        letter-spacing:0.08em; color:#666; display:flex; align-items:center;
    }

    /* Info */
    .info-label {
        font-size:0.7rem; font-weight:700; text-transform:uppercase;
        letter-spacing:0.05em; color:#555; display:block; margin-bottom:4px;
    }
    .info-value {
        background:#161616; border:1px solid #2A2A2A; border-radius:6px;
        padding:8px 12px; color:#ddd; font-size:0.875rem;
    }

    /* Timeline */
    .timeline-item { display:flex; align-items:flex-start; gap:12px; }
    .tl-dot {
        width:10px; height:10px; border-radius:50%;
        margin-top:5px; flex-shrink:0;
    }
    .dot-orange { background:#FF7A00; box-shadow:0 0 6px #FF7A00; }
    .dot-green  { background:#198754; box-shadow:0 0 6px #198754; }
    .dot-empty  { background:#333; border:1px solid #444; }

    /* Cost */
    .cost-display { text-align:center; padding:8px 0; }
    .cost-label { font-size:0.7rem; color:#555; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:4px; }
    .cost-amount { font-size:1.8rem; font-weight:800; color:#FF7A00; }
    .cost-amount span { font-size:1rem; font-weight:600; margin-left:4px; }

    /* Highlight field */
    .highlight-field {
        background:rgba(255,122,0,0.06); border:1px solid rgba(255,122,0,0.2);
        border-radius:8px; padding:10px 14px; color:#ddd; font-size:0.9rem;
        display:flex; align-items:center;
    }

    /* Note box */
    .note-box {
        background:#161616; border:1px solid #2A2A2A; border-radius:8px;
        padding:12px 14px; color:#ccc; font-size:0.875rem; line-height:1.6;
        min-height:80px;
    }

    /* Progress */
    .progress-track {
        height:4px; background:#2A2A2A; border-radius:4px; overflow:hidden;
    }
    .progress-fill { height:100%; border-radius:4px; transition:width 0.8s ease; }
    .fill-done    { width:100%; background:linear-gradient(90deg, #198754, #20c997); }
    .fill-ongoing { width:50%;  background:linear-gradient(90deg, #FF7A00, #ffc107); animation: pulse-width 2s ease-in-out infinite; }

    @@keyframes pulse-width {
        0%, 100% { opacity:1; }
        50%       { opacity:0.6; }
    }

    .step-label { font-size:0.72rem; font-weight:600; }
    .step-active   { color:#FF7A00; }
    .step-done     { color:#198754; }
    .step-inactive { color:#444; }
</style>
