@model QuanLyThueXe.Models.BaoDuong

@{
    ViewData["Title"] = "Chỉnh sửa phiếu bảo dưỡng";
}

<div class="container-fluid py-4 px-4" style="max-width:860px;">

    @* Breadcrumb *@
    <nav class="mb-2" style="font-size:0.82rem;">
        <a asp-action="Index" class="text-muted text-decoration-none hover-white">Bảo dưỡng</a>
        <span class="text-muted mx-2">›</span>
        <a asp-action="Details" asp-route-id="@Model.MaBaoDuong" class="text-muted text-decoration-none hover-white">#BD-@Model.MaBaoDuong.ToString("D3")</a>
        <span class="text-muted mx-2">›</span>
        <span class="text-white">Chỉnh sửa</span>
    </nav>

    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Details" asp-route-id="@Model.MaBaoDuong" class="btn-icon-back">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h3 class="fw-bold text-white mb-0">Chỉnh sửa phiếu Bảo dưỡng</h3>
            <p class="text-muted small mb-0">Cập nhật thông tin phiếu bảo dưỡng #BD-@Model.MaBaoDuong.ToString("D3")</p>
        </div>
    </div>

    <div class="form-panel">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MaBaoDuong" />
            <input type="hidden" asp-for="NgayTao" />
            <input type="hidden" asp-for="TrangThai" />

            @* Thông tin xe *@
            <div class="section-header">
                <i class="fa-solid fa-motorcycle me-2"></i> Thông tin xe
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-12">
                    <label class="field-label">Chọn xe <span class="text-danger">*</span></label>
                    <select asp-for="MaXe" asp-items="ViewBag.DanhSachXe" class="dark-select w-100">
                        <option value="">-- Chọn xe --</option>
                    </select>
                    <span asp-validation-for="MaXe" class="text-danger small"></span>
                </div>
            </div>

            @* Thông tin bảo dưỡng *@
            <div class="section-header">
                <i class="fa-solid fa-screwdriver-wrench me-2"></i> Thông tin bảo dưỡng
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-12">
                    <label class="field-label">Loại bảo dưỡng <span class="text-danger">*</span></label>
                    <input asp-for="LoaiBaoDuong" class="dark-input w-100"
                           placeholder="VD: Thay nhớt, Bảo dưỡng định kỳ 10.000km..." />
                    <span asp-validation-for="LoaiBaoDuong" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="field-label">Ngày vào <span class="text-danger">*</span></label>
                    <div class="input-icon-wrap">
                        <i class="fa-regular fa-calendar input-icon"></i>
                        <input asp-for="NgayVao" type="date" class="dark-input w-100 ps-5" />
                    </div>
                    <span asp-validation-for="NgayVao" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="field-label">Ngày ra dự kiến</label>
                    <div class="input-icon-wrap">
                        <i class="fa-regular fa-calendar input-icon"></i>
                        <input asp-for="NgayRa" type="date" class="dark-input w-100 ps-5" />
                    </div>
                    <span asp-validation-for="NgayRa" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="field-label">Đơn vị thực hiện</label>
                    <div class="input-icon-wrap">
                        <i class="fa-solid fa-building input-icon"></i>
                        <input asp-for="DonViThucHien" class="dark-input w-100 ps-5"
                               placeholder="VD: Gara Honda Quận 7..." />
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="field-label">Chi phí (VNĐ)</label>
                    <div class="input-icon-wrap">
                        <i class="fa-solid fa-dong-sign input-icon"></i>
                        <input asp-for="ChiPhi" type="number" class="dark-input w-100 ps-5"
                               placeholder="0" min="0" />
                    </div>
                    <span asp-validation-for="ChiPhi" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label class="field-label">Ghi chú</label>
                    <textarea asp-for="GhiChu" class="dark-textarea w-100" rows="3"
                              placeholder="Mô tả tình trạng xe, vật tư thay thế..."></textarea>
                </div>
            </div>

            @* Actions *@
            <div class="d-flex justify-content-end gap-3 pt-2" style="border-top:1px solid #2A2A2A;">
                <a asp-action="Details" asp-route-id="@Model.MaBaoDuong" class="btn-cancel px-4 py-2 fw-semibold">Hủy</a>
                <button type="submit" class="btn-save px-4 py-2 fw-semibold">
                    <i class="fa-regular fa-floppy-disk me-2"></i> Lưu thay đổi
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelector('input[name="NgayVao"]')?.addEventListener('change', function() {
            var ngayRaInput = document.querySelector('input[name="NgayRa"]');
            if (ngayRaInput) ngayRaInput.min = this.value;
        });
    </script>
}

<style>
    .hover-white:hover {
        color: #fff !important;
    }

    .btn-icon-back {
        width: 36px;
        height: 36px;
        background: #2A2A2A;
        border: none;
        border-radius: 8px;
        color: #aaa;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        flex-shrink: 0;
        transition: all 0.2s;
    }

        .btn-icon-back:hover {
            background: #333;
            color: #fff;
        }

    .form-panel {
        background: #1E1E1E;
        border: 1px solid #2A2A2A;
        border-radius: 14px;
        padding: 28px;
    }

    .section-header {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #666;
        padding-bottom: 10px;
        margin-bottom: 16px;
        border-bottom: 1px solid #2A2A2A;
        display: flex;
        align-items: center;
    }

    .field-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #555;
        display: block;
        margin-bottom: 6px;
    }

    .dark-input, .dark-select, .dark-textarea {
        background: #161616 !important;
        border: 1px solid #2A2A2A !important;
        color: #fff !important;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 0.875rem;
        transition: border-color 0.2s;
    }

        .dark-input:focus, .dark-select:focus, .dark-textarea:focus {
            border-color: #FF7A00 !important;
            box-shadow: 0 0 0 3px rgba(255,122,0,0.1) !important;
            outline: none;
        }

        .dark-input::placeholder, .dark-textarea::placeholder {
            color: #444 !important;
        }

    .dark-textarea {
        resize: vertical;
        min-height: 90px;
    }

    .input-icon-wrap {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #555;
        pointer-events: none;
        z-index: 2;
    }

    .btn-cancel {
        background: #2A2A2A;
        color: #aaa;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
    }

        .btn-cancel:hover {
            background: #333;
            color: #fff;
        }

    .btn-save {
        background: #FF7A00;
        color: #111;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
    }

        .btn-save:hover {
            background: #e86d00;
        }

        .btn-save:active {
            transform: scale(0.97);
        }
</style>
