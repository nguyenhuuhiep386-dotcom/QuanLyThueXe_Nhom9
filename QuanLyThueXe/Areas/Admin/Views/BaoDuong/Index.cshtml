@model IEnumerable<QuanLyThueXe.Models.BaoDuong>

@{
    ViewData["Title"] = "Quản lý Bảo dưỡng";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-white mb-1">Quản lý Bảo dưỡng</h3>
            <p class="text-muted small mb-0">Theo dõi lịch sử và trạng thái bảo dưỡng xe</p>
        </div>
        <a asp-action="Create" class="btn-add">
            <i class="fa-solid fa-plus me-2"></i> Tạo phiếu bảo dưỡng
        </a>
    </div>

    @* Stat cards *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(255,122,0,0.12); color:#FF7A00;">
                    <i class="fa-solid fa-screwdriver-wrench"></i>
                </div>
                <div>
                    <div class="stat-label">Tổng phiếu</div>
                    <div class="stat-value">@(Model?.Count() ?? 0)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(255,193,7,0.12); color:#ffc107;">
                    <i class="fa-solid fa-gears"></i>
                </div>
                <div>
                    <div class="stat-label">Đang sửa</div>
                    <div class="stat-value">@(Model?.Count(b => b.TrangThai == "DangSua") ?? 0)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(25,135,84,0.12); color:#198754;">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <div class="stat-label">Hoàn thành</div>
                    <div class="stat-value">@(Model?.Count(b => b.TrangThai == "HoanThanh") ?? 0)</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(13,110,253,0.12); color:#4d8fff;">
                    <i class="fa-solid fa-sack-dollar"></i>
                </div>
                <div>
                    <div class="stat-label">Tổng chi phí</div>
                    <div class="stat-value" style="font-size:1rem;">
                        @((Model?.Where(b => b.ChiPhi.HasValue).Sum(b => b.ChiPhi ?? 0) ?? 0).ToString("N0"))đ
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Filter *@
    <div class="filter-box mb-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="filter-label">Trạng thái</label>
                <select name="trangThai" class="dark-select">
                    <option value="">Tất cả</option>
                    <option value="DangSua" selected="@(ViewBag.TrangThai == "DangSua" ? "selected" : null)">Đang sửa</option>
                    <option value="HoanThanh" selected="@(ViewBag.TrangThai == "HoanThanh" ? "selected" : null)">Hoàn thành</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="filter-label">Từ ngày</label>
                <input type="date" name="tuNgay" class="dark-input-sm"
                       value="@ViewBag.TuNgay" />
            </div>
            <div class="col-md-3">
                <label class="filter-label">Đến ngày</label>
                <input type="date" name="denNgay" class="dark-input-sm"
                       value="@ViewBag.DenNgay" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn-filter flex-fill">
                    <i class="fa-solid fa-magnifying-glass me-1"></i> Lọc
                </button>
                <a asp-action="Index" class="btn-reset">
                    <i class="fa-solid fa-rotate-left"></i>
                </a>
            </div>
        </form>
    </div>

    @* Table *@
    <div class="table-wrap">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead>
                <tr class="table-head">
                    <th class="ps-4">Mã phiếu</th>
                    <th>Xe</th>
                    <th>Loại bảo dưỡng</th>
                    <th>Đơn vị thực hiện</th>
                    <th>Ngày vào</th>
                    <th>Ngày ra</th>
                    <th class="text-end">Chi phí</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-4">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="table-row">
                            <td class="ps-4">
                                <span class="ma-phieu">BD-@item.MaBaoDuong.ToString("D3")</span>
                            </td>
                            <td>
                                <div class="xe-cell">
                                    <div class="xe-dot"></div>
                                    <div>
                                        <div class="text-white fw-medium" style="font-size:0.88rem;">@(item.Xe?.TenXe ?? "—")</div>
                                        <div class="text-muted" style="font-size:0.75rem;">@(item.Xe?.BienSo ?? "")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="loai-badge">@item.LoaiBaoDuong</span>
                            </td>
                            <td class="text-muted" style="font-size:0.85rem;">
                                @(item.DonViThucHien ?? "—")
                            </td>
                            <td class="text-muted" style="font-size:0.85rem;">
                                @item.NgayVao.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-muted" style="font-size:0.85rem;">
                                @(item.NgayRa.HasValue ? item.NgayRa.Value.ToString("dd/MM/yyyy") : "—")
                            </td>
                            <td class="text-end">
                                @if (item.ChiPhi.HasValue)
                                {
                                    <span class="text-white fw-medium" style="font-size:0.88rem;">
                                        @item.ChiPhi.Value.ToString("N0")đ
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.TrangThai == "DangSua")
                                {
                                    <span class="status-badge status-pending">
                                        <span class="status-dot"></span> Đang sửa
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-done">
                                        <span class="status-dot"></span> Hoàn thành
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-3">
                                    <a asp-action="Details" asp-route-id="@item.MaBaoDuong"
                                       class="action-btn" title="Xem chi tiết">
                                        <i class="fa-regular fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.MaBaoDuong"
                                       class="action-btn" title="Chỉnh sửa">
                                        <i class="fa-regular fa-pen-to-square"></i>
                                    </a>
                                    @if (item.TrangThai == "DangSua")
                                    {
                                        <form asp-action="HoanThanh" asp-route-id="@item.MaBaoDuong"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="action-btn text-success border-0 bg-transparent p-0"
                                                    title="Đánh dấu hoàn thành">
                                                <i class="fa-regular fa-circle-check"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-5">
                            <i class="fa-solid fa-screwdriver-wrench text-muted mb-3" style="font-size:2rem; display:block;"></i>
                            <span class="text-muted">Chưa có phiếu bảo dưỡng nào.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="table-footer">
            <span class="text-muted small">Tổng: <strong class="text-white">@(Model?.Count() ?? 0)</strong> phiếu</span>
        </div>
    </div>

</div>

<style>
    /* Stat cards */
    .stat-card {
        background:#1E1E1E; border:1px solid #2A2A2A; border-radius:12px;
        padding:16px 20px; display:flex; align-items:center; gap:16px;
    }
    .stat-icon {
        width:44px; height:44px; border-radius:10px;
        display:flex; align-items:center; justify-content:center;
        font-size:1.1rem; flex-shrink:0;
    }
    .stat-label { font-size:0.72rem; color:#666; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; }
    .stat-value { font-size:1.3rem; font-weight:700; color:#fff; line-height:1.2; }

    /* Filter */
    .filter-box {
        background:#1E1E1E; border:1px solid #2A2A2A;
        border-radius:12px; padding:20px;
    }
    .filter-label {
        font-size:0.72rem; font-weight:700; text-transform:uppercase;
        letter-spacing:0.05em; color:#555; display:block; margin-bottom:6px;
    }
    .dark-select, .dark-input-sm {
        width:100%; background:#161616 !important; border:1px solid #2A2A2A !important;
        color:#fff !important; border-radius:8px; padding:9px 12px;
        font-size:0.85rem;
    }
    .dark-select:focus, .dark-input-sm:focus {
        border-color:#FF7A00 !important; outline:none;
        box-shadow:0 0 0 3px rgba(255,122,0,0.1) !important;
    }

    /* Buttons */
    .btn-add {
        background:#FF7A00; color:#111; border:none; border-radius:8px;
        padding:10px 20px; font-weight:700; font-size:0.85rem;
        text-decoration:none; transition:all 0.2s; display:inline-flex; align-items:center;
    }
    .btn-add:hover { background:#e86d00; color:#000; }

    .btn-filter {
        background:#2A2A2A; color:#ccc; border:none; border-radius:8px;
        padding:9px 16px; font-size:0.85rem; cursor:pointer; transition:all 0.2s;
    }
    .btn-filter:hover { background:#333; color:#fff; }

    .btn-reset {
        background:#1A1A1A; color:#666; border:1px solid #2A2A2A;
        border-radius:8px; padding:9px 14px; text-decoration:none;
        display:flex; align-items:center; transition:all 0.2s;
    }
    .btn-reset:hover { color:#FF7A00; border-color:#FF7A00; }

    /* Table */
    .table-wrap {
        background:#1E1E1E; border:1px solid #2A2A2A;
        border-radius:12px; overflow:hidden;
    }
    .table-head th {
        background:#1A1A1A; color:#555; font-size:0.72rem;
        font-weight:700; text-transform:uppercase; letter-spacing:0.06em;
        padding:14px 12px; border:none;
    }
    .table-row td { border-color:#222 !important; padding:12px; }
    .table-row:hover td { background:rgba(255,122,0,0.03) !important; }

    .ma-phieu { color:#666; font-size:0.82rem; font-family:monospace; }

    .xe-cell { display:flex; align-items:center; gap:10px; }
    .xe-dot {
        width:8px; height:8px; border-radius:50%;
        background:#FF7A00; box-shadow:0 0 6px #FF7A00; flex-shrink:0;
    }

    .loai-badge {
        background:#161616; border:1px solid #2A2A2A; border-radius:6px;
        padding:3px 10px; font-size:0.78rem; color:#aaa;
        display:inline-block; max-width:160px;
        overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
    }

    /* Status */
    .status-badge {
        display:inline-flex; align-items:center; gap:6px;
        padding:4px 12px; border-radius:20px; font-size:0.78rem; font-weight:500;
    }
    .status-dot { width:6px; height:6px; border-radius:50%; display:inline-block; }

    .status-pending {
        background:rgba(255,193,7,0.1); color:#ffc107; border:1px solid rgba(255,193,7,0.2);
    }
    .status-pending .status-dot { background:#ffc107; box-shadow:0 0 4px #ffc107; }

    .status-done {
        background:rgba(25,135,84,0.1); color:#198754; border:1px solid rgba(25,135,84,0.2);
    }
    .status-done .status-dot { background:#198754; box-shadow:0 0 4px #198754; }

    /* Action buttons */
    .action-btn {
        color:#555; text-decoration:none; font-size:1rem;
        transition:color 0.15s; background:none; border:none; padding:0; cursor:pointer;
    }
    .action-btn:hover { color:#fff; }

    /* Footer */
    .table-footer {
        padding:12px 16px; border-top:1px solid #222;
        background:#1A1A1A;
    }
</style>
