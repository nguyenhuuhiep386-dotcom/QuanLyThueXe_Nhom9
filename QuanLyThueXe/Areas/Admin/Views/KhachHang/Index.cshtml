@model IEnumerable<QuanLyThueXe.Models.KhachHang>

@{
    ViewData["Title"] = "Quản lý Khách hàng";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">

        <!-- Khối form tìm kiếm mới -->
        <form asp-action="Index" method="get" class="d-flex align-items-center gap-2" style="width: 600px;">
            <div class="search-box position-relative flex-grow-1">
                <i class="fa-solid fa-search position-absolute text-muted" style="top: 50%; left: 20px; transform: translateY(-50%);"></i>
                <!-- Dùng ViewBag.CurrentSearch để giữ lại chữ khách vừa gõ -->
                <input type="text" name="search" value="@ViewBag.CurrentSearch" class="form-control bg-dark border-secondary text-white rounded-pill py-2" style="padding-left: 45px;" placeholder="Tìm tên, SĐT, CMND, Email...">
            </div>

            <!-- Nút Tìm kiếm -->
            <button type="submit" class="btn rounded-pill px-4 py-2 fw-bold" style="background-color: rgba(255, 122, 0, 0.1); color: #FF7A00; border: 1px solid #FF7A00;">
                Tìm kiếm
            </button>

            <!-- Nút Reset (Chỉ hiện ra khi đang có từ khóa tìm kiếm) -->
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string))
            {
                <a asp-action="Index" class="btn rounded-pill px-3 py-2 text-muted" style="background-color: #2A2A2A; border: 1px solid #444;" title="Xóa tìm kiếm">
                    <i class="fa-solid fa-rotate-left me-1"></i> Xóa
                </a>
            }
        </form>

        <a asp-action="Create" class="btn fw-bold px-4 py-2 text-dark" style="background-color: #FF7A00; border-radius: 8px;">
            + Thêm khách hàng mới
        </a>
    </div>

    <div class="dashboard-card p-0 overflow-hidden" style="border-radius: 12px; background-color: #1E1E1E; border: 1px solid #2A2A2A;">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr class="text-muted small text-uppercase" style="border-bottom: 1px solid #2A2A2A;">
                        <th class="py-4 px-4 border-0 fw-semibold" style="letter-spacing: 0.5px;">ID</th>
                        <th class="py-4 px-3 border-0 fw-semibold" style="letter-spacing: 0.5px;">Họ và Tên</th>
                        <th class="py-4 px-3 border-0 fw-semibold" style="letter-spacing: 0.5px;">Số điện thoại</th>
                        <th class="py-4 px-3 border-0 fw-semibold" style="letter-spacing: 0.5px;">Email</th>
                        <th class="py-4 px-3 border-0 fw-semibold" style="letter-spacing: 0.5px;">Số GPLX</th>
                        <th class="py-4 px-3 border-0 fw-semibold" style="letter-spacing: 0.5px;">CMND/CCCD</th>
                        <th class="py-4 px-3 border-0 fw-semibold" style="letter-spacing: 0.5px;">Địa chỉ</th>
                        <th class="py-4 px-4 border-0 fw-semibold text-end" style="letter-spacing: 0.5px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid #2A2A2A; transition: background-color 0.2s;">
                                <td class="py-3 px-4 text-muted">CUS-@item.MaKhachHang.ToString("D3")</td>
                                <td class="py-3 px-3 text-white fw-medium">@item.HoTen</td>
                                <td class="py-3 px-3 text-muted">@item.SoDienThoai</td>
                                <td class="py-3 px-3 text-muted">@item.Email</td>
                                <td class="py-3 px-3 text-muted">@(string.IsNullOrEmpty(item.SoGPLX) ? "-" : item.SoGPLX)</td>
                                <td class="py-3 px-3">
                                    <span class="badge me-1" style="background-color: rgba(255,122,0,0.1); color: #FF7A00; border: 1px solid rgba(255,122,0,0.3);">
                                        @(item.LoaiGiayTo?.TenLoai ?? "Giấy tờ")
                                    </span>

                                    <span class="text-white fw-medium">
                                        @(string.IsNullOrEmpty(item.SoGiayTo) ? "Đang cập nhật" : item.SoGiayTo)
                                    </span>
                                </td>
                                <td class="py-3 px-3 text-muted text-truncate" style="max-width: 200px;" title="@item.DiaChi">@item.DiaChi</td>
                                <td class="py-3 px-4 text-end">
                                    <div class="d-flex justify-content-end gap-3 fs-5">
                                        <button type="button" onclick="xemLichSu(@item.MaKhachHang)" class="text-muted text-decoration-none hover-white border-0 bg-transparent p-0" title="Lịch sử thuê">
                                            <i class="fa-solid fa-clock-rotate-left"></i>
                                        </button>
                                        <a asp-action="Edit" asp-route-id="@item.MaKhachHang" class="text-muted text-decoration-none hover-orange" title="Chỉnh sửa">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.MaKhachHang" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khách hàng này?');" style="margin: 0; display: inline;">
                                            <button type="submit" class="text-muted text-decoration-none hover-red border-0 bg-transparent p-0" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-users-slash mb-3 fs-1 opacity-50"></i>
                                <p class="mb-0">Hệ thống chưa có dữ liệu khách hàng nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center p-3 border-top border-secondary" style="background-color: #1A1A1A;">
            <span class="text-muted small">Hiển thị 1-5 trên tổng số @(Model?.Count() ?? 0) khách hàng</span>
            <nav>
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item disabled"><a class="page-link bg-transparent border-secondary text-muted rounded" href="#">&lt;</a></li>
                    <li class="page-item active"><a class="page-link border-0 text-dark fw-bold rounded" style="background-color: #FF7A00;" href="#">1</a></li>
                    <li class="page-item"><a class="page-link bg-transparent border-secondary text-muted rounded hover-bg-orange" href="#">2</a></li>
                    <li class="page-item"><a class="page-link bg-transparent border-secondary text-muted rounded hover-bg-orange" href="#">3</a></li>
                    <li class="page-item"><a class="page-link bg-transparent border-secondary text-muted rounded hover-bg-orange" href="#">&gt;</a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    /* CSS làm mượt các hiệu ứng hover cho Icon và Nút bấm */
    .hover-white:hover {
        color: #fff !important;
    }

    .hover-orange:hover {
        color: #FF7A00 !important;
    }

    .hover-red:hover {
        color: #dc3545 !important;
    }

    .hover-bg-orange:hover {
        background-color: rgba(255, 122, 0, 0.1) !important;
        color: #FF7A00 !important;
        border-color: #FF7A00 !important;
    }

    /* Đổi màu viền xanh mặc định của Bootstrap khi focus vào thanh tìm kiếm */
    .search-box input:focus {
        box-shadow: 0 0 0 0.25rem rgba(255, 122, 0, 0.25);
        border-color: #FF7A00 !important;
    }
</style>
<div class="modal fade" id="historyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="background-color: #1E1E1E; border: 1px solid #444; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title text-white fw-bold">
                    <i class="fa-solid fa-clock-rotate-left me-2" style="color: #FF7A00;"></i> Lịch sử giao dịch
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="historyModalBody">
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border" style="color: #FF7A00;" role="status"></div>
                    <div class="mt-3">Đang tải dữ liệu...</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function xemLichSu(id) {
            // 1. Hiện cái Modal lên trước
            var myModal = new bootstrap.Modal(document.getElementById('historyModal'));
            myModal.show();

            // 2. Set lại giao diện loading phòng khi bấm sang người khác
            document.getElementById('historyModalBody').innerHTML = '<div class="text-center py-5 text-muted"><div class="spinner-border" style="color: #FF7A00;" role="status"></div><div class="mt-3">Đang tải dữ liệu...</div></div>';

            // 3. Gọi AJAX xuống Server lấy file _LichSuThue.cshtml lên
            fetch('/Admin/KhachHang/LichSuThue/' + id)
                .then(response => response.text())
                .then(html => {
                    // 4. Nhét HTML lấy được vào giữa cái Modal
                    document.getElementById('historyModalBody').innerHTML = html;
                })
                .catch(error => {
                    document.getElementById('historyModalBody').innerHTML = '<div class="text-center text-danger py-4">Lỗi tải dữ liệu! Vui lòng thử lại sau.</div>';
                });
        }
    </script>
}