@model IEnumerable<QuanLyThueXe.Models.HopDong>

@if (Model != null && Model.Any())
{
    <div class="table-responsive rounded-3" style="border: 1px solid #2A2A2A;">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead style="background-color: #1A1A1A;">
                <tr class="text-muted small text-uppercase">
                    <th class="py-3 px-3 border-0">Mã HĐ</th>
                    <th class="py-3 px-3 border-0">Xe thuê</th>
                    <th class="py-3 px-3 border-0">Thời gian</th>
                    <th class="py-3 px-3 border-0 text-end">Tổng tiền</th>
                    <th class="py-3 px-3 border-0 text-center">Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid #2A2A2A;">
                        <td class="py-2 px-3 text-muted">HD-@item.MaHopDong.ToString("D3")</td>
                        <td class="py-2 px-3 text-white">@(item.Xe?.TenXe ?? "Xe đã xóa")</td>
                        <td class="py-2 px-3">
                            <div class="text-white small">@item.NgayThue.ToString("dd/MM/yyyy") - @item.NgayTra.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td class="py-2 px-3 text-end text-white">@item.TongTien.ToString("N0") đ</td>
                        <td class="py-2 px-3 text-center">
                            @if (item.TrangThai == "ChoXacNhan")
                            {
                                <span class="badge text-dark" style="background-color: #ffc107;">Chờ XN</span>
                            }
                            else if (item.TrangThai == "DangThue")
                            {

                                <span class="badge" style="background-color: #0d6efd;">Đang thuê</span>
                            }
                            else
                            {

                                <span class="badge" style="background-color: #198754;">Hoàn thành</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3 text-end p-2 rounded-2" style="background-color: rgba(255, 122, 0, 0.1); border: 1px dashed rgba(255,122,0,0.3);">
        <span class="text-muted small text-uppercase me-2">Tổng chi tiêu:</span>
        <span class="fw-bold fs-5" style="color: #FF7A00;">@Model.Sum(x => x.TongTien).ToString("N0") VNĐ</span>
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-file-contract mb-3 fs-2 opacity-50"></i>
        <p class="mb-0">Khách hàng này chưa thuê chiếc xe nào.</p>
    </div>
}