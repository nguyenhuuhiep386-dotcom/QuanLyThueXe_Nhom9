@model QuanLyThueXe.Models.HopDong

@{
    ViewData["Title"] = "Chi tiết Hợp đồng";
    var soNgay = (Model.NgayTra - Model.NgayThue).Days;
    if (soNgay < 1) soNgay = 1;
}

<div class="container-fluid py-4 px-4" style="max-width: 1200px;">

    <p class="text-muted small mb-2">Chi tiết hợp đồng</p>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-icon-back">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <h4 class="fw-bold text-white mb-0">
                Chi tiết Hợp đồng
                <span class="text-muted fw-normal" style="font-size: 0.95rem;">#@Model.MaHopDong.ToString("D4")</span>
            </h4>

            @if (Model.TrangThai == "ChoXacNhan")
            {
                <span class="status-badge status-pending">Chờ xác nhận</span>
            }
            else if (Model.TrangThai == "DangThue")
            {
                <span class="status-badge status-active">Đang thuê</span>
            }
            else if (Model.TrangThai == "DaTra")
            {
                <span class="status-badge status-done">Đã hoàn thành</span>
            }
            else if (Model.TrangThai == "DaHuy")
            {
                <span class="status-badge status-cancelled">Đã hủy</span>
            }
        </div>

        <a href="#" onclick="window.print()" class="btn btn-outline-secondary text-muted px-3 py-2" style="background:#1E1E1E; border:1px solid #2A2A2A; border-radius:8px; font-size:0.85rem;">
            <i class="fa-regular fa-file-lines me-2"></i> In hợp đồng
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" style="background:rgba(25,135,84,0.1); border:1px solid rgba(25,135,84,0.3); color:#198754; border-radius:10px;" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" style="background:rgba(220,53,69,0.1); border:1px solid rgba(220,53,69,0.3); color:#dc3545; border-radius:10px;" role="alert">
            <i class="fa-solid fa-circle-xmark me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="detail-card p-4" style="background:#1E1E1E; border:1px solid #2A2A2A; border-radius:14px;">
        <div class="row g-4">

            <div class="col-md-4">
                <div class="section-box mb-3">
                    <div class="section-title mb-3">
                        <i class="fa-regular fa-user me-2 text-muted"></i>
                        <span>Thông tin khách hàng</span>
                    </div>

                    <div class="info-field mb-3">
                        <label class="info-label">Họ và tên</label>
                        <div class="info-value">@(Model.KhachHang?.HoTen ?? "—")</div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="info-label">Số điện thoại</label>
                            <div class="info-value">@(Model.KhachHang?.SoDienThoai ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <label class="info-label">Email</label>
                            <div class="info-value text-truncate" title="@Model.KhachHang?.Email">@(Model.KhachHang?.Email ?? "—")</div>
                        </div>
                    </div>

                    <div class="row g-2">
                        <div class="col-6">
                            <label class="info-label">Số GPLX</label>
                            <div class="info-value">@(Model.KhachHang?.SoGPLX ?? "—")</div>
                        </div>
                        <div class="col-6">
                            <label class="info-label">CMND/CCCD</label>
                            <div class="info-value">@(Model.KhachHang?.SoGiayTo ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="section-box">
                    <div class="section-title mb-3">
                        <i class="fa-solid fa-motorcycle me-2 text-muted"></i>
                        <span>Thông tin xe</span>
                    </div>

                    <div class="d-flex gap-3 align-items-start">
                        @if (!string.IsNullOrEmpty(Model.Xe?.AnhDaiDien))
                        {
                            <img src="@Model.Xe.AnhDaiDien" alt="Ảnh xe"
                                 style="width:80px; height:60px; object-fit:cover; border-radius:8px; border:1px solid #2A2A2A;" />
                        }
                        else
                        {
                            <div style="width:80px; height:60px; background:#2A2A2A; border-radius:8px; display:flex; align-items:center; justify-content:center;">
                                <i class="fa-solid fa-motorcycle text-muted fs-4"></i>
                            </div>
                        }
                        <div>
                            <div class="text-white fw-semibold">@(Model.Xe?.TenXe ?? "—")</div>
                            <div class="text-muted small mt-1">@(Model.Xe?.BienSo ?? "—")</div>
                            <div class="mt-2">
                                <span class="text-muted small">Giá thuê/ngày</span><br />
                                <span class="text-orange fw-semibold">@(Model.GiaThueGoc.ToString("N0")) VNĐ</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="col-md-8">
                <div class="section-box">
                    <div class="section-title mb-3">
                        <i class="fa-regular fa-calendar me-2 text-muted"></i>
                        <span>Lịch trình & Chi phí</span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="timeline-item mb-3">
                                <div class="timeline-dot dot-done"></div>
                                <div>
                                    <div class="info-label">Ngày thuê</div>
                                    <div class="info-value">@Model.NgayThue.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>

                            <div class="timeline-item mb-3">
                                <div class="timeline-dot @(Model.NgayTra < DateTime.Now && Model.TrangThai == "DangThue" ? "dot-warning" : "dot-pending")"></div>
                                <div>
                                    <div class="info-label">Ngày trả dự kiến</div>
                                    <div class="info-value">@Model.NgayTra.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>

                            <div class="timeline-item">
                                <div class="timeline-dot @(Model.NgayTraThucTe.HasValue ? "dot-done" : "dot-empty")"></div>
                                <div>
                                    <div class="info-label">Ngày trả thực tế</div>
                                    <div class="info-value">
                                        @(Model.NgayTraThucTe.HasValue ? Model.NgayTraThucTe.Value.ToString("dd/MM/yyyy") : "—")
                                    </div>
                                </div>
                            </div>

                            <div class="mt-3 pt-3" style="border-top:1px solid #2A2A2A;">
                                <span class="info-label">Tổng số ngày thuê</span>
                                <span class="text-white fw-semibold ms-3">@soNgay ngày</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <div class="info-label mb-2">Ghi chú vận hành</div>
                                <div class="ghi-chu-box p-3" style="background:#161616; border:1px solid #2A2A2A; border-radius:8px; min-height:80px; font-size:0.875rem; color:#ccc; line-height:1.6;">
                                    @if (!string.IsNullOrEmpty(Model.GhiChu))
                                    {
                                        @Model.GhiChu
                                    }
                                    else
                                    {
                                        <span class="text-muted">Không có ghi chú.</span>
                                    }
                                </div>
                            </div>

                            <div class="cost-breakdown p-3" style="background:#161616; border:1px solid #2A2A2A; border-radius:8px;">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Giá thuê gốc</span>
                                    <span class="text-white small">@Model.GiaThueGoc.ToString("N0") × @soNgay ngày</span>
                                </div>

                                @if (Model.HeSoMua != 1.00m)
                                {
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small">Hệ số mùa</span>
                                        <span class="text-warning small">× @Model.HeSoMua</span>
                                    </div>
                                }

                                @if (Model.PhuPhiTreHan > 0)
                                {
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small">Phụ phí trễ hạn</span>
                                        <span class="text-danger small">+ @Model.PhuPhiTreHan.ToString("N0")</span>
                                    </div>
                                }

                                <div class="pt-2 mt-1" style="border-top:1px solid #2A2A2A;">
                                    <div class="text-muted small text-end mb-1">TỔNG TIỀN THANH TOÁN</div>
                                    <div class="text-end fw-bold text-orange" style="font-size:1.6rem; letter-spacing:-0.5px;">
                                        @((Model.TongTien + Model.PhuPhiTreHan).ToString("N0")) VNĐ
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="d-flex justify-content-end gap-3 mt-4">

        @if (Model.TrangThai != "DaTra" && Model.TrangThai != "DaHuy")
        {
            <button type="button" class="btn btn-huy px-4 py-2 fw-semibold"
                    data-bs-toggle="modal" data-bs-target="#modalHuy">
                <i class="fa-regular fa-circle-xmark me-2"></i> Hủy hợp đồng
            </button>
        }

        @if (Model.TrangThai == "ChoXacNhan")
        {
            <a asp-action="XacNhanGiayTo" asp-route-id="@Model.MaHopDong"
               class="btn btn-xacnhan px-4 py-2 fw-semibold">
                <i class="fa-regular fa-circle-check me-2"></i> Xác nhận Giấy tờ
            </a>
        }

        @if (Model.TrangThai == "DangThue")
        {
            <button type="button" class="btn btn-traxe px-4 py-2 fw-semibold"
                    data-bs-toggle="modal" data-bs-target="#modalTraXe">
                <i class="fa-solid fa-flag-checkered me-2"></i> Bàn giao xe
            </button>
        }

    </div>
</div>
<div class="modal fade" id="modalHuy" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:#1E1E1E; border:1px solid #2A2A2A; border-radius:14px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold">Hủy hợp đồng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Huy" asp-route-id="@Model.MaHopDong" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body pt-3">
                    <p class="text-muted small mb-3">Vui lòng nhập lý do hủy hợp đồng này.</p>
                    <textarea name="lyDoHuy" class="form-control dark-input" rows="3"
                              placeholder="Ví dụ: Khách hàng yêu cầu hủy..." required></textarea>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-cancel px-4 py-2 fw-semibold" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-huy px-4 py-2 fw-semibold">Xác nhận hủy</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="modalTraXe" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:#1E1E1E; border:1px solid #2A2A2A; border-radius:14px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-white fw-bold">Bàn giao xe</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="TraXe" asp-route-id="@Model.MaHopDong" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body pt-3">
                    <p class="text-muted small mb-3">
                        Ngày trả dự kiến: <strong class="text-white">@Model.NgayTra.ToString("dd/MM/yyyy")</strong>
                    </p>
                    <label class="info-label mb-1">Ngày trả thực tế</label>
                    <input type="date" name="ngayTraThucTe" class="form-control dark-input"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-cancel px-4 py-2 fw-semibold" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-traxe px-4 py-2 fw-semibold">Xác nhận trả xe</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .text-orange { color: #FF7A00; }

    /* Section box */
    .section-box {
        background: #161616;
        border: 1px solid #2A2A2A;
        border-radius: 10px;
        padding: 20px;
    }

    .section-title {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #888;
        display: flex;
        align-items: center;
    }

    /* Info fields */
    .info-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #666;
        display: block;
        margin-bottom: 4px;
    }

    .info-value {
        background: #1E1E1E;
        border: 1px solid #2A2A2A;
        border-radius: 6px;
        padding: 8px 12px;
        color: #e0e0e0;
        font-size: 0.9rem;
    }

    /* Timeline */
    .timeline-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .timeline-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-top: 5px;
        flex-shrink: 0;
    }

    .dot-done    { background: #198754; box-shadow: 0 0 6px #198754; }
    .dot-pending { background: #ffc107; box-shadow: 0 0 6px #ffc107; }
    .dot-warning { background: #dc3545; box-shadow: 0 0 6px #dc3545; }
    .dot-empty   { background: #444; border: 1px solid #555; }

    /* Buttons */
    .btn-icon-back {
        background: #2A2A2A;
        border: none;
        border-radius: 8px;
        color: #aaa;
        width: 36px; height: 36px;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.2s, color 0.2s;
    }
    .btn-icon-back:hover { background: #333; color: #fff; }

    .btn-huy {
        background: rgba(220,53,69,0.1);
        color: #dc3545;
        border: 1px solid rgba(220,53,69,0.3);
        border-radius: 8px;
        transition: background 0.2s;
    }
    .btn-huy:hover { background: rgba(220,53,69,0.2); color: #ff4d5e; }

    .btn-xacnhan {
        background: rgba(13,110,253,0.15);
        color: #4d8fff;
        border: 1px solid rgba(13,110,253,0.3);
        border-radius: 8px;
        transition: background 0.2s;
    }
    .btn-xacnhan:hover { background: rgba(13,110,253,0.25); color: #80aaff; }

    .btn-traxe {
        background: #FF7A00;
        color: #111;
        border: none;
        border-radius: 8px;
        transition: background 0.2s, transform 0.1s;
    }
    .btn-traxe:hover  { background: #e86d00; }
    .btn-traxe:active { transform: scale(0.97); }

    .btn-cancel {
        background: #2A2A2A;
        color: #aaa;
        border: none;
        border-radius: 8px;
    }
    .btn-cancel:hover { background: #333; color: #fff; }

    /* Status badges */
    .status-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 7px;
    }
    .status-badge::before {
        content: '';
        width: 6px; height: 6px;
        border-radius: 50%;
        display: inline-block;
    }

    .status-pending   { background: rgba(255,193,7,0.1); color:#ffc107; border:1px solid rgba(255,193,7,0.25); }
    .status-pending::before   { background:#ffc107; box-shadow:0 0 4px #ffc107; }

    .status-active    { background: rgba(13,110,253,0.1); color:#4d8fff; border:1px solid rgba(13,110,253,0.25); }
    .status-active::before    { background:#4d8fff; box-shadow:0 0 4px #4d8fff; }

    .status-done      { background: rgba(25,135,84,0.1); color:#198754; border:1px solid rgba(25,135,84,0.25); }
    .status-done::before      { background:#198754; box-shadow:0 0 4px #198754; }

    .status-cancelled { background: rgba(220,53,69,0.1); color:#dc3545; border:1px solid rgba(220,53,69,0.25); }
    .status-cancelled::before { background:#dc3545; box-shadow:0 0 4px #dc3545; }

    /* Dark input for modal */
    .dark-input {
        background: #161616 !important;
        border: 1px solid #2A2A2A !important;
        color: #fff !important;
        border-radius: 8px !important;
        padding: 10px 14px;
    }
    .dark-input:focus {
        border-color: #FF7A00 !important;
        box-shadow: 0 0 0 3px rgba(255,122,0,0.12) !important;
        outline: none;
    }
</style>
